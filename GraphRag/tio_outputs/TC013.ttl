@prefix icm:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentCommonModel/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex:   <http://example.org/tio-instance/TC013/> .

ex:intent a icm:Intent ;
  icm:context ex:ctx .

ex:ctx a icm:Context ;
  rdfs:comment "Time window from 23:00 to 06:00."@en .

ex:tgt a icm:Target ;
  rdfs:comment "Enterprise backup traffic."@en .

ex:exp-prop a icm:PropertyExpectation ;
  icm:target ex:tgt ;
  rdfs:comment "Backup traffic should stay below 200 Mbps during the specified time window."@en .

ex:target-property-values icm:valuesOfTargetProperty rdf:value .