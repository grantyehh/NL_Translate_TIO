@prefix icm:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentCommonModel/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex:   <http://example.org/tio-instance/TC015/> .

ex:intent a icm:Intent .
ex:tgt-vip a icm:Target ;
  rdfs:comment "VIP users' video service."@en .
ex:tgt-regular a icm:Target ;
  rdfs:comment "Regular users' video service."@en .
ex:exp-del a icm:DeliveryExpectation ;
  icm:target ex:tgt-vip ;
  rdfs:comment "Ensure VIP users' download speed is at least twice that of regular users."@en .
ex:comparison a icm:Comparison ;
  icm:target ex:tgt-regular ;
  rdfs:comment "Comparison baseline for regular users' download speed."@en .