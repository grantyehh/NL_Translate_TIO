@prefix icm:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentCommonModel/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex:   <http://example.org/tio-instance/TC004/> .

ex:intent a icm:Intent ;
  icm:context ex:ctx .
ex:ctx a icm:Context ;
  rdfs:comment "Weekday working hours (08:00-18:00)."@en .
ex:tgt a icm:Target ;
  rdfs:comment "Bandwidth management system of the office building."@en .
ex:exp-priority a icm:PropertyExpectation ;
  icm:target ex:tgt ;
  rdfs:comment "Set bandwidth priority to the highest level."@en .