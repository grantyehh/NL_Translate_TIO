@prefix icm:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentCommonModel/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex:   <http://example.org/tio-instance/TC001/> .

ex:intent a icm:Intent .
ex:exp-del a icm:DeliveryExpectation ;
  icm:target ex:tgt ;
  rdfs:comment "Establish a 5G slice service."@en .
ex:tgt a icm:Target ;
  rdfs:comment "Connectivity scope between Taipei and Taichung."@en .