@prefix icm:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentCommonModel/> .
@prefix log:  <http://tio.models.tmforum.org/tio/v3.6.0/LogicalOperators/> .
@prefix quan: <http://tio.models.tmforum.org/tio/v3.6.0/QuantityOntology/> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex:   <http://example.org/tio-instance/TC018/> .

ex:intent a icm:Intent ;
  icm:context ex:ctx .

ex:ctx a icm:Context ;
  rdfs:comment "Condition for wireless resource allocation adjustment."@en .

ex:cond a log:Condition ;
  rdfs:comment "Packet loss rate of factory wireless sensors exceeds 3% for 5 consecutive minutes."@en .

ex:tgt a icm:Target ;
  rdfs:comment "Wireless resources in the specified area."@en .

ex:exp a icm:Expectation ;
  icm:target ex:tgt ;
  rdfs:comment "Immediately enhance wireless resource allocation."@en .

ex:target-property-values icm:valuesOfTargetProperty rdf:value .