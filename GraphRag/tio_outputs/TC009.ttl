@prefix icm:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentCommonModel/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex:   <http://example.org/tio-instance/TC009/> .

ex:intent a icm:Intent .
ex:tgt-fire-rescue a icm:Target ;
  rdfs:comment "Communication traffic for fire and rescue units."@en .
ex:tgt-general-public a icm:Target ;
  rdfs:comment "Communication traffic for the general public."@en .
ex:exp-priority a icm:DeliveryExpectation ;
  icm:target ex:tgt-fire-rescue ;
  rdfs:comment "Ensure fire and rescue communication traffic always has priority over general public traffic."@en .