@prefix icm:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentCommonModel/> .
@prefix log:  <http://tio.models.tmforum.org/tio/v3.6.0/LogicalOperators/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix t:    <http://www.w3.org/2006/time#> .
@prefix ex:   <http://example.org/tio-instance/TC012/> .

ex:intent a icm:Intent ;
  log:condition ex:cond ;
  icm:expectation ex:exp-del .

ex:cond a log:Condition ;
  rdfs:comment "Data center main link is down."@en .

ex:tgt a icm:Target ;
  rdfs:comment "Backup dedicated line for traffic."@en .

ex:exp-del a icm:DeliveryExpectation ;
  icm:target ex:tgt ;
  rdfs:comment "Switch traffic to backup line within 30 seconds."@en ;
  t:hasDuration [
    a t:Duration ;
    t:seconds 30
  ] .