@prefix icm:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentCommonModel/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex:   <http://example.org/tio-instance/TC003/> .

ex:intent a icm:Intent .
ex:tgt a icm:Target ;
  rdfs:comment "Enterprise private network in Hsinchu campus."@en .
ex:exp-availability a icm:PropertyExpectation ;
  icm:target ex:tgt ;
  rdfs:comment "Ensure availability reaches 99.99%."@en .
ex:target-property-values icm:valuesOfTargetProperty rdf:value .