@prefix icm:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentCommonModel/> .
@prefix log:  <http://tio.models.tmforum.org/tio/v3.6.0/LogicalOperators/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex:   <http://example.org/tio-instance/TC019/> .

ex:intent a icm:Intent ;
  icm:context ex:ctx ;
  icm:condition ex:cond ;
  icm:expectation ex:exp-del .

ex:ctx a icm:Context ;
  rdfs:comment "Time window from 01:00 to 05:00."@en .

ex:cond a log:Condition ;
  rdfs:comment "No high-priority business is active."@en .

ex:tgt a icm:Target ;
  rdfs:comment "Small cell base stations in the business district."@en .

ex:exp-del a icm:DeliveryExpectation ;
  icm:target ex:tgt ;
  rdfs:comment "Switch to energy-saving mode."@en .