@prefix icm:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentCommonModel/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix t:    <http://www.w3.org/2006/time#> .

<http://example.org/tio-instance/TC017/intent> a icm:Intent .
<http://example.org/tio-instance/TC017/exp-del> a icm:DeliveryExpectation ;
  icm:target <http://example.org/tio-instance/TC017/tgt> ;
  rdfs:comment "Smart meter data should be successfully returned at least once per day."@en ;
  t:hasTemporalUnit t:unitDay ;
  t:numericDuration "1"^^xsd:integer .
<http://example.org/tio-instance/TC017/tgt> a icm:Target ;
  rdfs:comment "Smart meter data."@en .