@prefix icm:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentCommonModel/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex:   <http://example.org/tio-instance/TC016/> .

ex:intent a icm:Intent .
ex:tgt a icm:Target ;
  rdfs:comment "Financial transaction API traffic."@en .
ex:exp-del a icm:DeliveryExpectation ;
  icm:target ex:tgt ;
  rdfs:comment "Traffic must only pass through dedicated slices with encryption protection."@en .