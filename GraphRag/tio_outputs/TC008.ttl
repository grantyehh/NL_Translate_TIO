@prefix icm:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentCommonModel/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/tio-instance/TC008/intent> a icm:Intent .
<http://example.org/tio-instance/TC008/exp-del> a icm:DeliveryExpectation ;
  icm:target <http://example.org/tio-instance/TC008/tgt> ;
  rdfs:comment "Ensure upload throughput of at least 500 Mbps for medical imaging service."@en .
<http://example.org/tio-instance/TC008/tgt> a icm:Target ;
  rdfs:comment "Medical imaging upload service."@en .