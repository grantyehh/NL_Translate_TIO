@prefix icm:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentCommonModel/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex:   <http://example.org/tio-instance/TC008/> .

ex:intent a icm:Intent .
ex:tgt a icm:Target ;
  rdfs:comment "Medical image upload service."@en .
ex:exp-throughput a icm:PropertyExpectation ;
  icm:target ex:tgt ;
  rdfs:comment "Ensure uplink throughput is at least 500 Mbps."@en .
ex:target-property-values icm:valuesOfTargetProperty rdf:value .