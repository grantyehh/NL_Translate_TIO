@prefix icm:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentCommonModel/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex:   <http://example.org/tio-instance/TC011/> .

ex:intent a icm:Intent ;
  icm:context ex:ctx .

ex:ctx a icm:Context ;
  rdfs:comment "During large concerts."@en .

ex:tgt a icm:Target ;
  rdfs:comment "Mobile network around Taipei Arena."@en .

ex:exp-capacity a icm:DeliveryExpectation ;
  icm:target ex:tgt ;
  rdfs:comment "Increase mobile network capacity to twice the usual."@en .