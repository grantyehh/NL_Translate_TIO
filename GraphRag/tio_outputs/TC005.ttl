@prefix icm:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentCommonModel/> .
@prefix log:  <http://tio.models.tmforum.org/tio/v3.6.0/LogicalOperators/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex:   <http://example.org/tio-instance/TC005/> .

ex:intent a icm:Intent .
ex:cond a log:Condition ;
  rdfs:comment "Base station load exceeds 80%."@en .
ex:tgt a icm:Target ;
  rdfs:comment "Non-essential video streaming."@en .
ex:exp-prop a icm:PropertyExpectation ;
  icm:target ex:tgt ;
  rdfs:comment "Automatically limit the bandwidth of non-essential video streaming."@en .