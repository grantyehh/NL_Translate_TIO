  rdfs:seeAlso <https://www.tmforum.org/resources/introductory-guide/tr291c-proposal-of-best-intent-intent-extension-model-v3-6-0/> ;
  rdfs:seeAlso <https://www.tmforum.org/resources/standard/ig1358-intent-based-operation-user-guide-v1-0-0/> ;
  skos:changeNote "2024-10-16 - initial draft of turtle file"@en 
.

pbi:BestProposalExpectation
  rdfs:label "Best Proposal Expectation Class"@en ;
  rdfs:comment "The class pbi:BestProposalExpectation is used to request proposals of best intent. It is a subclass of icm:ReportingExpectation, which also implies that the proposal is communicated through an intent report."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf icm:ReportingExpectation
.

pbi:BestProposalReport
  rdfs:label "Best Proposal Report Class"@en ;
  rdfs:comment "The class pbi:BestProposalReport is used to provide the proposals corresponding to a best proposal expectation in the intent. It is a subclass of icm:ExpectationReport."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf icm:ExpectationReport
.

pbi:Proposal
  rdfs:label "Proposal Class"@en ;
  rdfs:comment "The class pbi:Proposal is used to provide an individual proposal. Typically, there a proposal created for every requirement in scope of a best proposal expectation as stated by its target."@en ;
  rdf:type rdfs:Class
.

pbi:proposal
  rdfs:label "Proposal Property"@en ;
  rdfs:comment "The property pbi:Proposal refers to the best intent proposals contained in the intent report."@en ;
  rdf:type rdf:Property ;
  rdfs:domain icm:IntentReport ;
  rdfs:range pbi:BestProposalReport
.

pbi:proposed
  rdfs:label "Proposed Property"@en ;
  rdfs:comment "The property pbi:proposed is used in the domain of a best proposal report to refer to an individual proposal."@en ;
  rdf:type rdf:Property ;
  rdfs:domain pbi:BestProposalReport ;
  rdfs:range pbi:Proposal
.

pbi:proposedFor
  rdfs:label "Proposed For Property"@en ;
  rdfs:comment "The property pbi:proposedFor is used to state what requirement object from the intent the proposal is made for."@en ;
  rdf:type rdf:Property ;
  rdfs:domain pbi:Proposal
.

pbi:proposedBest
  rdfs:label "Proposed Best"@en ;
  rdfs:comment "The property pbi:proposedBest refers to an object that states the proposed values."@en ;
  rdf:type rdf:Property ;
  rdfs:domain pbi:Proposal
.

pbi:Vocabulary
  rdfs:label "Proposal Best Intent Vocabulary"@en ;
  rdfs:comment "The object pbi:Vocabulary is a container of all model elements."@en ;
  rdf:type rdfs:Container ;
  rdfs:member pbi:BestProposalExpectation ,
              pbi:BestProposalReport ,
              pbi:Proposal ,
              pbi:proposal ,
              pbi:proposed ,
              pbi:proposedFor ,
              pbi:proposedBest
.
