<http://tio.models.tmforum.org/tio/v3.6.0/ProposalBestIntent/>
  rdf:type imo:IntentExtensionModel ;
  rdfs:label "Proposal Best Intent Model"@en ;
  rdfs:Comment "This model introduces the vocabulary for requesting and providing proposals for intent requirements."@en ;
  dct:title "Proposal Best Intent Model"@en ;
  dct:description "This model introduces the vocabulary for requesting and providing proposals for intent requirements."@en ;
  dct:subject "intent proposal"@en ,
              "intent expression"@en ;
  dct:identifier <http://tio.models.tmforum.org/tio/v3.6.0/ProposalBestIntent/> ;
  # dct:isPartOf <http://tio.models.tmforum.org/tio/v3.6.0/TMForumIntentOntology> ;
  dct:replaces <http://tio.models.tmforum.org/tio/v3.5.0/ProposalBestIntent/> ;
  dct:contributor <mailto:joerg.niemoeller@ericsson.com> ;
  dct:created "2024-10-16"^^xsd:date ;
  dct:creator <mailto:joerg.niemoeller@ericsson.com> ;
