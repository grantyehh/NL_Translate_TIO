# Quantity Ontology version 3.6.0

@prefix quan: <http://tio.models.tmforum.org/tio/v3.6.0/QuantityOntology/> .
@prefix fun:  <http://tio.models.tmforum.org/tio/v3.6.0/FunctionOntology/> .
@prefix imo:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentManagementOntology/> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

<http://tio.models.tmforum.org/tio/v3.6.0/QuantityOntology/>
  rdf:type imo:BaseOntologyModel ;
  rdfs:label "Quantity Ontology"@en ;
  rdfs:Comment "This ontology model defines quantities and a set of operator functions that allow to define, modify, combine and compare quantity objects. Quantities are objects that have a numerical value combined with a unit."@en ;
  dct:title "Quantity Defintion Ontology"@en ;
  dct:description "This ontology model defines quantities and a set of operator functions that allow to define, modify, combine and compare quantity objects. Quantities are objects that have a numerical value combined with a unit."@en ;
  dct:subject "quantity defintion"@en ,
              "intent expression"@en ;
  dct:identifier <http://tio.models.tmforum.org/tio/v3.6.0/QuantityOntology/> ;
  # dct:isPartOf <http://tio.models.tmforum.org/tio/v3.6.0/TMForumIntentOntology> ;
  dct:replaces <http://tio.models.tmforum.org/tio/v3.5.0/QuantityOntology/> ;
  dct:contributor <mailto:joerg.niemoeller@ericsson.com> ;
  dct:created "2024-10-09"^^xsd:date ;
  dct:creator <mailto:joerg.niemoeller@ericsson.com> ;
  dct:license <http://www.apache.org/licenses/LICENSE-2.0> ;
  dct:license <https://github.com/tmforum-apis/Intent_Repository> ;
  dct:modified "2024-10-09"^^xsd:date ;
  dct:rights "Copyright © 2024 TM Forum"@en ;
  dct:rightHolder "TM Forum" ;
  dct:publisher "TM Forum" ;
  rdfs:seeAlso <https://www.tmforum.org/resources/how-to-guide/ig1253-intent-in-autonomous-networks-v1-3-0/> ;
  rdfs:seeAlso <https://www.tmforum.org/resources/introductory-guide/tr292d-quantity-ontology-v3-6-0/> ;
  rdfs:seeAlso <https://www.tmforum.org/resources/standard/ig1358-intent-based-operation-user-guide-v1-0-0/> ;
  skos:changeNote "2024-10-09 - initial draft of turtle file"@en ;
.

quan:atLeast
  rdfs:label "At Least Function"@en ;
  rdfs:comment "The function quan:atLeast defines a comparison of quantities. It provides a boolean result and is evaluated as \"true\" if the quantity of the first argument is equal to or bigger than the quantity of the second argument. Unit prefixes are considered."@en ;
  rdf:type fun:Function ;
  fun:resultTtype xsd:boolean ;
  fun:arityMin 2 ;
  fun:arityMax 2 ;
  fun:argumentTypes ( quan:Quantity )
.

quan:atMost
  rdfs:label "At Most Function"@en ;
  rdfs:comment "The function quan:atMost defines a comparison of quantities. It provides a boolean result and is evaluated as \"true\" if the quantity of the first argument is equal to or smaller than the quantity of the second argument. Unit prefixes are considered."@en ;
  rdf:type fun:Function ;
  fun:resultType xsd:boolean ;
  fun:arityMin 2 ;
  fun:arityMax 2 ;
  fun:argumentTypes ( quan:Quantity )
.

quan:difference
  rdfs:label "Difference Function"@en ;
  rdfs:comment "The function quan:difference defines a mathematical operation that provides the numerical difference between two quantities. It has two arguments, and it evaluates to the difference of the first argument value minus the second argument value. Unit prefixes are considered in the calculation. The unit expression of the first argument is used for the result."@en ;
  rdf:type fun:Function ;
  fun:resultTtype quan:Quantity ;
  fun:arityMin 2 ;
  fun:arityMax 2 ;
  fun:argumentTypes ( quan:Quantity )
.

quan:division
  rdfs:label "Division Function"@en ;
  rdfs:comment "The function quan:division defines a mathematical operation that provides the result of a division of two quantities. The first argument is the numerator and the second the denominator of the division. The function therefore has exactly two arguments. Unit prefixes are considered in the calculation. Both arguments can have different units and the unit expression of the result is generated based on the units of the arguments."@en ;
  rdf:type fun:Function ;
  fun:resultTtype xsd:boolean ;
  fun:arityMin 2 ;
  fun:arityMax 2 ;
  fun:argumentTypes ( quan:Quantity )
.

quan:exactly
  rdfs:label "Exactly Function"@en ;
  rdfs:comment "The function quan:exactly defines a comparison of quantities. It provides a boolean result and is evaluated as \"true\" if the quantity of all arguments are the same. Unit prefixes are considered."@en ;
  rdf:type fun:Function ;
  fun:resultTtype xsd:boolean ;
  fun:arityMin 2 ;
  fun:argumentTypes ( quan:Quantity )
.

quan:greater
  rdfs:label "Greater Function"@en ;
  rdfs:comment "The function quan:greater defines a comparison of quantities. It provides a boolean result and is evaluated as true if the quantity of the first argument is greater than the quantity of the second argument. Unit prefixes are considered."@en ;
  rdf:type fun:Function ;
  fun:resultTtype xsd:boolean ;
  fun:arityMin 2 ;
  fun:arityMax 2 ; 
  fun:argumentTypes ( quan:Quantity )
.

quan:greatest
  rdfs:label "Greatest Function"@en ;
  rdfs:comment "The function quan:greatest provides a result that is the largest quantity across all quantities provided as arguments. If no argument is provided the result has value 0 without unit. Units and unit prefixes are considered."@en ;
  rdf:type fun:Function ;
  fun:resultTtype quan:Quantity ;
  fun:argumentTypes ( quan:Quantity )
.

quan:greatestInSet
  rdfs:label "Greatest In Set Function"@en ;
  rdfs:comment "The function quan:greatestInSet provides a result that is the largest quantity across all quantities across member elements of the union of all containers that are provided as arguments. If no argument is provided the result has value 0 without unit. Units and unit prefixes are considered."@en ;
  rdf:type fun:Function ;
  fun:resultTtype quan:Quantity ;
  fun:argumentTypes ( rdfs:Container )
.

quan:inRange
  rdfs:label "In Range Function"@en ;
  rdfs:comment "The function quan:inRange defines a comparison of quantities. It provides a boolean result and is evaluated as \"true\" if the value of the quantity of the first argument is equal to or greater than the quantity of the second argument and if it is equal to or smaller than the quantity of the third argument. Unit prefixes are considered."@en ;
  rdf:type fun:Function ;
  fun:resultTtype xsd:boolean ;
  fun:arityMin 3 ;
  fun:arityMax 3 ;
  fun:argumentTypes ( quan:Quantity )
.

quan:MonetaryQuantity
  rdfs:label "Monetary Quantity Class"@en ;
  rdfs:comment "The class quan:MonetaryQuantity refers to a quantity with currency based units."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf quan:quantity
.

quan:mean
  rdfs:label "Mean Function"@en ;
  rdfs:comment "The function quan:mean defines a mathematical operation that provides the arithmetic mean of quantities. The function can have any number of arguments of type quan:Quantity and the result is the arithmetic mean across all of them. The result is 0 with no unit if no argument is provided. If only one argument is given, then the result is identical with the argument. Units and unit prefixes are considered in the calculation. The arguments must have units that are of the same dimension and the unit assigned to the result is the unit of the first argument."@en ;
  rdf:type fun:Function ;
  fun:resultTtype quan:Quantity ;
  fun:arityMin 2 ;
  fun:argumentTypes ( quan:Quantity )
.

quan:meanOfSet
  rdfs:label "Mean Of Set Function"@en ;
  rdfs:comment "The function quan:meanOfSet defines a mathematical operation that provides the arithmetic mean of quantities. The function can have any number of arguments of type rdfs:Container and the result is the arithmetic mean across all member elements of the union of these containers. The result is 0 with no unit if no member element of type quan:quantity is provided by any of the argument containers. Units and unit prefixes are considered in the calculation. The arguments must have units that are of the same dimension and the unit assigned to the result is the unit of the first member element processed from the first argument container."@en ;
  rdf:type fun:Function ;
  fun:resultTtype quan:Quantity ;
  fun:arityMin 1 ;
  fun:argumentTypes ( rdfs:Container )
.

quan:median
  rdfs:label "Median Function"@en ;
  rdfs:comment "The function quan:median defines a mathematical operation that provides the median value of quantities. The function can have any number of arguments of type quan:Quantity and the result is the arithmetic median value across all of them. The result is 0 with no unit if no argument is provided. If only one argument is given, then the result is identical with the argument. Units and unit prefixes are considered in the calculation. The arguments must have units that are of the same dimension and the unit assigned to the result is the unit of the first argument."@en ;
  rdf:type fun:Function ;
  fun:resultTtype quan:Quantity ;
  fun:arityMin 2 ;
  fun:argumentTypes ( quan:Quantity )
.

quan:medianOfSet
  rdfs:label "Median Of Set Function"@en ;
  rdfs:comment "The function quan:medianOfSet defines a mathematical operation that provides the median value of quantities. The function can have any number of arguments of type rdfs:Container and the result is the median value across all member elements of the union of these containers. The result is 0 with no unit if no member element of type quan:quantity is provided by any of the argument containers. Units and unit prefixes are considered in the calculation. The arguments must have units that are of the same dimension and the unit assigned to the result is the unit of the first member element processed from the first argument container."@en ;
  rdf:type fun:Function ;
  fun:resultTtype quan:Quantity ;
  fun:arityMin 1 ;
  fun:argumentTypes ( rdfs:Container )
.

quan:multiplication
  rdfs:label "Multiplication Function"@en ;
  rdfs:comment "The function quan:multiplication defines a mathematical operation that provides the result of a multiplication of quantities. The function can have any number of arguments of type quan:Quantity and the result is the multiplication of all of them. The result is 0 with no unit if no argument is provided. If only one argument is given, then the result is identical with the argument. Units and unit prefixes are considered in the calculation. The result unit depends on the unit of contributing quantities and a suitable unit will be assigned."@en ;
  rdf:type fun:Function ;
  fun:resultTtype quan:Quantity ;
  fun:arityMin 2 ;
  fun:argumentTypes ( quan:Quantity )
.

quan:multiplicationOfSet
  rdfs:label "Multiplication Of Set Function"@en ;
  rdfs:comment "The function quan:multiplicationOfSet defines a mathematical operation that provides the result of a multiplication of quantities. The function can have any number of arguments of type rdfs:Container and the result is the multiplication of all member elements of the union of these containers. The result is 0 with no unit if no member element of type quan:Quantity is provided by any of the argument containers. Units and unit prefixes are considered in the calculation. The result unit depends on the unit of contributing quantities and a suitable unit will be assigned."@en ;
  rdf:type fun:Function ;
  fun:resultTtype quan:Quantity ;
  fun:arityMin 1 ;
  fun:argumentTypes ( rdfs:Container )
.

quan:Quantity
  rdfs:label "Quantity Class"@en ;
  rdfs:comment "The class quan:Quantity defines a structured datatype for representing a numerical value in combination with a unit expression."@en ;
  rdf:type rdfs:Class
.

quan:quantity
  rdfs:label "Quantity Datatype"@en ;
  rdfs:comment "The datatype quan:quantity is a string that contains a combination of numerical value and unit. A literal of this datatype is equivalent to an individual of class quan:Quantity with value and unit specified separately through the properties rdf:value and quan:unit."@en ;
  rdf:type rdfs:Datatype

.

quan:smaller
  rdfs:label "Smaller Function"@en ;
  rdfs:comment "The function quan:smaller defines a comparison of quantities. It provides a boolean result and is evaluated as true if the quantity of the first argument is smaller than the quantity of the second argument. Unit prefixes are considered."@en ;
  rdf:type fun:Function ;
  fun:resultTtype xsd:boolean ;
  fun:arityMin 2 ;
  fun:arityMax 2 ;
  fun:argumentTypes ( quan:Quantity )
.

quan:smallest
  rdfs:label "Smallest Function"@en ;
  rdfs:comment "The function quan:smallestInSet provides a result that is the smallest quantity across all quantities provided as arguments. If no argument is provided the result has value 0 without unit. Units and unit prefixes are considered."@en ;
  rdf:type fun:Function ;
  fun:resultTtype quan:Quantity ;
  fun:argumentTypes ( quan:Quantity ) 
.

quan:smallestInSet
  rdfs:label "Smallest In Set Function"@en ;
  rdfs:comment "The function quan:smallestInSet provides a result that is the smallest quantity across all quantities across member elements of the union of all containers that are provided as arguments. If no argument is provided the result has value 0 without unit. Units and unit prefixes are considered."@en ;
  rdf:type fun:Function ;
  fun:resultTtype quan:Quantity ;
  fun:argumentTypes ( rdfs:Container )
.

quan:sum
  rdfs:label "Sum Function"@en ;
  rdfs:comment "The function quan:sum defines a mathematical operation that provides the result of an addition of quantities. The function can have any number of arguments of type quan:Quantity and the result is the sum of all of them. The result is 0 with no unit if no argument is provided. If only one argument is given, then the result is identical with the argument. Units and unit prefixes are considered in the calculation. The arguments must have units that are of the same dimension and the unit assigned to the result is the unit of the first argument."@en ;
  rdf:type fun:Function ;
  fun:resultTtype quan:Quantity ;
  fun:arityMin 2 ;
  fun:argumentTypes ( quan:Quantity )
.

quan:sumOfSet
  rdfs:label "Sum Of Set Function"@en ;
  rdfs:comment "The function quan:sumOfSet defines a mathematical operation that provides the result of an addition of quantities. The function can have any number of arguments of type rdfs:Container and the result is the sum of all member elements of the union of these containers. The result is 0 with no unit if no member element of type quan:quantity is provided by any of the argument containers. Units and unit prefixes are considered in the calculation. The arguments must have units that are of the same dimension and the unit assigned to the result is the unit of the first member element processed from the first argument container."@en ;
  rdf:type fun:Function ;
  fun:resultTtype quan:Quantity ;
  fun:arityMin 1 ;
  fun:argumentTypes ( rdfs:Container )
.

quan:unit
  rdfs:label "Unit Property"@en ;
  rdfs:comment "The property quan:unit assigns a unit to a quantity."@en ;
  rdf:type rdf:Property ;
  rdfs:domain quan:Quantity ;
  rdfs:range xsd:string
.

quan:Vocabulary
  rdfs:label "Quantity Vocabulary"@en ;
  rdfs:comment "The object quan:Vocabulary is a container of all model elements."@en ;
  rdf:type rdfs:Container ;
  rdfs:member quan:atLeast ,
              quan:atMost ,
              quan:difference ,
              quan:division ,
              quan:exactly ,
              quan:greater ,
              quan:greatest ,
              quan:greatestInSet ,
              quan:inRange ,
              quan:MonetaryQuantity ,
              quan:mean ,
              quan:meanOfSet ,
              quan:median ,
              quan:medianOfSet ,
              quan:multiplication ,
              quan:multiplicationOfSet ,
              quan:Quantity ,
              quan:quantity ,
              quan:smaller ,
              quan:smallest ,
              quan:smallestInSet ,
              quan:sum ,
              quan:sumOfSet ,
              quan:unit 
.

