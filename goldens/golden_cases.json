      {"subject": "?expectation1", "predicate": "rdf:type", "object": "icm:PropertyExpectation"},
      {"subject": "?expectation1", "predicate": "icm:target", "object": "?target"},
      {"subject": "?target", "predicate": "rdf:type", "object": "icm:Target"}
