[
  {
    "id": "TC001",
    "nl_intent": "在台北和台中之間建立一個 5G 切片服務。",
    "golden_ttl_file": "goldens/TC001.ttl",
    "must_have_elements": [
      "icm:Intent",
      "icm:DeliveryExpectation",
      "icm:Target"
    ],
    "must_have_triples": [
      {"subject": "?intent", "predicate": "rdf:type", "object": "icm:Intent"},
      {"subject": "?delivery_exp", "predicate": "rdf:type", "object": "icm:DeliveryExpectation"},
      {"subject": "?delivery_exp", "predicate": "icm:target", "object": "?target"},
      {"subject": "?target", "predicate": "rdf:type", "object": "icm:Target"}
    ],
    "expected_values": [
      {"label": "5g slice service", "operator": "deliver", "value": "5G slice", "unit": null, "keywords": ["5g", "slice", "service", "taipei", "taichung"]}
    ],
    "must_not_have_predicates": ["icm:condition"],
    "notes": "最基本的 delivery 型 intent。"
  },
  {
    "id": "TC003",
