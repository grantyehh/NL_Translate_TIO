      {"subject": "?prop_exp", "predicate": "rdf:type", "object": "icm:PropertyExpectation"},
      {"subject": "?prop_exp", "predicate": "icm:target", "object": "?target"},
      {"subject": "?target", "predicate": "rdf:type", "object": "icm:Target"}
    ],
    "expected_values": [
      {"label": "availability target", "operator": ">=", "value": 99.99, "unit": "%", "keywords": ["availability", "enterprise", "network"]}
    ],
    "must_not_have_predicates": ["icm:hasValue"],
    "notes": "重點是 availability 百分比目標與正確的 property expectation 結構。"
  },
  {
    "id": "TC002",
