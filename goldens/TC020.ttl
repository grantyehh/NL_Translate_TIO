@prefix icm:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentCommonModel/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/tio-instance/TC020/intent>
  a icm:Intent ;
  icm:context <http://example.org/tio-instance/TC020/context> .

<http://example.org/tio-instance/TC020/context>
  a icm:Context ;
  rdfs:comment "Remote surgery is in progress."@en .

<http://example.org/tio-instance/TC020/control-target>
  a icm:Target ;
  rdfs:comment "Target for control signaling."@en .

<http://example.org/tio-instance/TC020/video-target>
  a icm:Target ;
  rdfs:comment "Target for 8K video streaming."@en .

<http://example.org/tio-instance/TC020/control-latency-expectation>
  a icm:PropertyExpectation ;
  icm:target <http://example.org/tio-instance/TC020/control-target> ;
  rdfs:comment "Control signal latency should stay below 5 ms."@en .

<http://example.org/tio-instance/TC020/video-delivery-expectation>
  a icm:DeliveryExpectation ;
  icm:target <http://example.org/tio-instance/TC020/video-target> ;
  rdfs:comment "8K video stream should be maintained without interruption."@en .
