@prefix icm:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentCommonModel/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/tio-instance/TC017/intent>
  a icm:Intent .

<http://example.org/tio-instance/TC017/delivery-expectation>
  a icm:DeliveryExpectation ;
  icm:target <http://example.org/tio-instance/TC017/target> ;
  rdfs:comment "Smart meter data should be successfully returned at least once per day."@en .

<http://example.org/tio-instance/TC017/target>
  a icm:Target ;
  rdfs:comment "Smart meter data stream."@en .
