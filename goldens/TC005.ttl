@prefix icm:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentCommonModel/> .
@prefix log:  <http://tio.models.tmforum.org/tio/v3.6.0/LogicalOperators/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/tio-instance/TC005/intent>
  a icm:Intent .

<http://example.org/tio-instance/TC005/load-condition>
  a log:Condition ;
  rdfs:comment "Base station load is greater than 80%."@en .

<http://example.org/tio-instance/TC005/limit-expectation>
  a icm:PropertyExpectation ;
  icm:target <http://example.org/tio-instance/TC005/target> ;
  rdfs:comment "Limit bandwidth for non-essential video streaming."@en .

<http://example.org/tio-instance/TC005/target>
  a icm:Target ;
  rdfs:comment "Non-essential video streaming flows."@en .
