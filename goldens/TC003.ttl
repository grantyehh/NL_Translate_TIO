@prefix icm:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentCommonModel/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/tio-instance/TC003/intent>
  a icm:Intent .

<http://example.org/tio-instance/TC003/availability-expectation>
  a icm:PropertyExpectation ;
  icm:target <http://example.org/tio-instance/TC003/target> ;
  rdfs:comment "Availability should be at least 99.99 percent."@en .

<http://example.org/tio-instance/TC003/target>
  a icm:Target ;
  rdfs:comment "Enterprise private network in Hsinchu Science Park."@en .
