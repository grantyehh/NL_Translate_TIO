@prefix icm:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentCommonModel/> .
@prefix log:  <http://tio.models.tmforum.org/tio/v3.6.0/LogicalOperators/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/tio-instance/TC012/intent>
  a icm:Intent .

<http://example.org/tio-instance/TC012/failure-condition>
  a log:Condition ;
  rdfs:comment "Main data-center link interruption."@en .

<http://example.org/tio-instance/TC012/switchover-expectation>
  a icm:DeliveryExpectation ;
  icm:target <http://example.org/tio-instance/TC012/target> ;
  rdfs:comment "Traffic should switch to backup line within 30 seconds."@en .

<http://example.org/tio-instance/TC012/target>
  a icm:Target ;
  rdfs:comment "Backup leased line."@en .
