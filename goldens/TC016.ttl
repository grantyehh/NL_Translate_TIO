@prefix icm:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentCommonModel/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/tio-instance/TC016/intent>
  a icm:Intent .

<http://example.org/tio-instance/TC016/delivery-expectation>
  a icm:DeliveryExpectation ;
  icm:target <http://example.org/tio-instance/TC016/target> ;
  rdfs:comment "Traffic should be delivered only via an encrypted dedicated slice."@en .

<http://example.org/tio-instance/TC016/target>
  a icm:Target ;
  rdfs:comment "Financial transaction API traffic."@en .
