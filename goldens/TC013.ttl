@prefix icm:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentCommonModel/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/tio-instance/TC013/intent>
  a icm:Intent ;
  icm:context <http://example.org/tio-instance/TC013/context> .

<http://example.org/tio-instance/TC013/context>
  a icm:Context ;
  rdfs:comment "Every night from 23:00 to 06:00."@en .

<http://example.org/tio-instance/TC013/bandwidth-limit-expectation>
  a icm:PropertyExpectation ;
  icm:target <http://example.org/tio-instance/TC013/target> ;
  rdfs:comment "Enterprise backup traffic should stay below 200 Mbps."@en .

<http://example.org/tio-instance/TC013/target>
  a icm:Target ;
  rdfs:comment "Enterprise backup flows."@en .
