@prefix icm:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentCommonModel/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/tio-instance/TC007/intent>
  a icm:Intent .

<http://example.org/tio-instance/TC007/delivery-expectation>
  a icm:DeliveryExpectation ;
  icm:target <http://example.org/tio-instance/TC007/target> ;
  rdfs:comment "Add indoor 5G coverage service."@en .

<http://example.org/tio-instance/TC007/target>
  a icm:Target ;
  rdfs:comment "Tainan Science Park indoor area."@en .
