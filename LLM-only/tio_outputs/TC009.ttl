@prefix icm:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentCommonModel/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/tio-instance/TC009/intent> a icm:Intent .
<http://example.org/tio-instance/TC009/exp-prop> a icm:PropertyExpectation ;
  icm:target <http://example.org/tio-instance/TC009/tgt-emergency> ;
  rdfs:comment "Emergency services communication traffic should always have higher priority than general public traffic."@en .
<http://example.org/tio-instance/TC009/tgt-emergency> a icm:Target ;
  rdfs:comment "Emergency services communication traffic."@en .
<http://example.org/tio-instance/TC009/tgt-public> a icm:Target ;
  rdfs:comment "General public communication traffic."@en .