@prefix icm:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentCommonModel/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/tio-instance/TC007/intent> a icm:Intent .
<http://example.org/tio-instance/TC007/exp-del> a icm:DeliveryExpectation ;
  icm:target <http://example.org/tio-instance/TC007/tgt> ;
  rdfs:comment "Add indoor 5G coverage service for Tainan Science Park."@en .
<http://example.org/tio-instance/TC007/tgt> a icm:Target ;
  rdfs:comment "Indoor 5G coverage in Tainan Science Park."@en .