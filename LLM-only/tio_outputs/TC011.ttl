@prefix icm:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentCommonModel/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/tio-instance/TC011/intent> a icm:Intent ;
  icm:context <http://example.org/tio-instance/TC011/ctx> .
<http://example.org/tio-instance/TC011/ctx> a icm:Context ;
  rdfs:comment "During a large concert event."@en .
<http://example.org/tio-instance/TC011/exp-prop> a icm:PropertyExpectation ;
  icm:target <http://example.org/tio-instance/TC011/tgt> ;
  rdfs:comment "Mobile network capacity around Taipei Arena should be increased to twice the normal level."@en .
<http://example.org/tio-instance/TC011/tgt> a icm:Target ;
  rdfs:comment "Mobile network around Taipei Arena."@en .