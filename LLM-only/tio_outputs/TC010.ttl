@prefix icm:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentCommonModel/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/tio-instance/TC010/intent> a icm:Intent .
<http://example.org/tio-instance/TC010/exp-prop> a icm:PropertyExpectation ;
  icm:target <http://example.org/tio-instance/TC010/tgt> ;
  rdfs:comment "Network availability should not be less than 99.95% throughout the year."@en .
<http://example.org/tio-instance/TC010/tgt> a icm:Target ;
  rdfs:comment "Taichung MRT monitoring network."@en .