  dct:modified "2024-10-16"^^xsd:date ;
  dct:rights "Copyright © 2024 TM Forum"@en ;
  dct:rightHolder "TM Forum" ;
  dct:publisher "TM Forum" ;
  rdfs:seeAlso <https://www.tmforum.org/resources/how-to-guide/ig1253-intent-in-autonomous-networks-v1-3-0/> ;
  rdfs:seeAlso <https://www.tmforum.org/resources/introductory-guide/tr291b-intent-probing-intent-extension-model-v3-6-0/> ;
  rdfs:seeAlso <https://www.tmforum.org/resources/standard/ig1358-intent-based-operation-user-guide-v1-0-0/> ;
  skos:changeNote "2024-10-16 - initial draft of turtle file"@en 
.

pro:expectedObservation
  rdfs:label "Expected Observation Property"@en ;
  rdfs:comment "The property pro:expectedObservation states predicted values for metrics rather than actually observed ones."@en ;
  rdf:type rdf:Property ;
  rdfs:range icm:Observation
.

pro:expectedResult
  rdfs:label "Expexted Result Property"@en ;
  rdfs:comment "The property pro:expectedResult is used to state the predicted evaluation result for a probed intent."@en ;
  rdf:type rdf:Property ;
  rdfs:domain xsd:Boolean
.

pro:Vocabulary
  rdfs:label "Intent Probing Vocabulary"@en ;
  rdfs:comment "The object pro:Vocabulary is a container of all model elements."@en ;
  rdf:type rdfs:Container ;
  rdfs:member pro:expectedObservation ,
              pro:expectedResult
.
