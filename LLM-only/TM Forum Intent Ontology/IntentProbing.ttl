@prefix dct:  <http://purl.org/dc/terms/> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

<http://tio.models.tmforum.org/tio/v3.6.0/IntentProbing/>
  rdf:type imo:IntentExtensionModel ;
  rdfs:label "Intent Probing Model"@en ;
  rdfs:Comment "This model introduces the vocabulary for requesting and providing proposals for intent requirements."@en ;
  dct:title "Intent Probing Model"@en ;
  dct:description "This model introduces the vocabulary for requesting and providing proposals for intent requirements."@en ;
  dct:subject "intent probing"@en ,
              "intent expression"@en ;
  dct:identifier <http://tio.models.tmforum.org/tio/v3.6.0/IntentProbing/> ;
  # dct:isPartOf <http://tio.models.tmforum.org/tio/v3.6.0/TMForumIntentOntology> ;
  dct:replaces <http://tio.models.tmforum.org/tio/v3.5.0/IntentProbing/> ;
  dct:contributor <mailto:joerg.niemoeller@ericsson.com> ;
  dct:created "2024-10-16"^^xsd:date ;
