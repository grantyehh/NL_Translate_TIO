# Intent Specification Model v3.6.0

@prefix insp: <http://tio.models.tmforum.org/tio/v3.6.0/IntentSpecification/> .
@prefix icm:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentCommonModel/> .
@prefix imo:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentManagementOntology/> .
@prefix fun:  <http://tio.models.tmforum.org/tio/v3.6.0/FunctionOntology/> .
@prefix met:  <http://tio.models.tmforum.org/tio/v3.6.0/MetricsAndObservations/> .
@prefix log:  <http://tio.models.tmforum.org/tio/v3.6.0/LogicalOperators/> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

<http://tio.models.tmforum.org/tio/v3.6.0/IntentSpecification/>
  rdf:type imo:TIOmodel ;
  rdfs:label "IntentSpecification"@en ;
  rdfs:Comment "An intent specification defines rules and constraints regarding allowed content of intent expressions."@en ;
  dct:title "IntentSpecification"@en ;
  dct:description "An intent specification defines rules and constraints regarding allowed content of intent expressions."@en ;
  dct:subject "intent specification"@en ,
              "intent template"@en ;
  dct:identifier <http://tio.models.tmforum.org/tio/v3.6.0/IntentSpecification/> ;
  # dct:isPartOf <http://tio.models.tmforum.org/tio/v3.6.0/TMForumIntentOntology> ;
  dct:replaces <http://tio.models.tmforum.org/tio/v3.5.0/IntentSpecification/> ;
  dct:contributor <mailto:joerg.niemoeller@ericsson.com> ;
  dct:created "2024-10-16"^^xsd:date ;
  dct:creator <mailto:joerg.niemoeller@ericsson.com> ;
  dct:license <http://www.apache.org/licenses/LICENSE-2.0> ;
  dct:license <https://github.com/tmforum-apis/Intent_Repository> ;
  dct:modified "2024-10-16"^^xsd:date ;
  dct:rights "Copyright © 2024 TM Forum"@en ;
  dct:rightHolder "TM Forum" ;
  dct:publisher "TM Forum" ;
  rdfs:seeAlso <https://www.tmforum.org/resources/how-to-guide/ig1253-intent-in-autonomous-networks-v1-3-0/> ;
  rdfs:seeAlso <https://www.tmforum.org/resources/introductory-guide/tr299-intent-specification-v3-6-0/> ;
  rdfs:seeAlso <https://www.tmforum.org/resources/standard/ig1358-intent-based-operation-user-guide-v1-0-0/> ;
  skos:changeNote "2024-10-16 - initial draft of turtle file"@en 
.

insp:allowedValues
  rdfs:label "Allowed Values Property"@en ;
  rdfs:comment "The property insp:allowedValues is used to specify the set of candidate objects or values to choose from for substituting the object template in its domain within a conforming intent expression."@en ;
  rdf:type rdf:Property ;
  rdfs:domain insp:ObjectTemplate ;
  rdfs:range rdfs:Container
.

insp:alternative
  rdfs:label "Alternative Property"@en ;
  rdfs:comment "The property insp:alternative specifies alternative content within intent specifications. Its range contains a list of all content templates representing viable alternatives. Each content template in the list alternative represents a statement or set of statements. Exactly one of these content templates and its statements needs to be used in place of insp:alternative when expressing an intent. This means a conforming intent expression must include a set of statements for every inst:alternative statement in the intent specification."@en ;
  rdf:type rdf:Property ;
  rdfs:range insp:ContentTemplate
.

insp:applicableIf
  rdfs:label "Applicable If Property"@en ;
  rdfs:comment "The property insp:applicableIf specifies that the content template in its domain is applicable to the intent expression if the condition in its range evaluates to true."@en ;
  rdf:type rdf:Property ;
  rdfs:domain insp:ContentTemplate ;
  rdfs:range log:Condition
.

insp:applicableIfNot
  rdfs:label "Applicable If Not Property"@en ;
  rdfs:comment "The property insp:applicableIfNot specifies that the content template in its domain is applicable to the intent expression if the condition in its range evaluates to false."@en ;
  rdf:type rdf:Property ;
  rdfs:domain insp:ContentTemplate ;
  rdfs:range log:Condition
.

insp:availableVocabulary
  rdfs:label "Available Vocabulary Property"@en ;
  rdfs:comment "The property insp:availableVocabulary assigns a vocabulary template to an intent within an intent specification. It implies that the intent and all its elements can only be expressed using the vocabulary specified by the vocabulary template. Multiple insp:availableVocabulary assigned to the same subject are interpreted as union of the individual vocabulary templates."@en ;
  rdf:type rdf:Property ;
  rdfs:range insp:VocabularyTemplate
.

insp:chosenAll
  rdfs:label "Chosen All Function"@en ;
  rdfs:comment "The operator insp:chosenAll indicates true, if all content templates referred to by its arguments were chosen."@en ;
  rdfs:comment "<xsd:boolean> = insp:chosenAll ( <insp:ContentTemplate> ... )"@en ;
  rdf:type fun:Function ;
  fun:resultType xsd:boolean ;
  fun:arityMin 1 ;
  fun:argumentTypes ( insp:ContentTemplate ) 
.

insp:chosenAllFor
  rdfs:label "Chosen All For Function"@en ;
  rdfs:comment "The operator insp:chosenAllFor indicates true, if for the intent element instance given as first argument all content templates referred to by its second and further arguments were chosen."@en ;
  rdfs:comment "<xsd:boolean> = insp:chosenAllFor ( <intent element> <insp:ContentTemplate> ... )"@en ;
  rdf:type fun:Function ;
  fun:resultType xsd:boolean ;
  fun:arityMin 2 ;
  fun:argumentTypes ( rdfs:Resource insp:ContentTemplate ) ;
  rdfs:Comment "The first argument is of type rdfs:Resource. It is referring to an element of the intent. The second and remaining arguments have type insp:ContentTemplate."@en
.

insp:chosenAny
  rdfs:label "Chosen Any Function"@en ;
  rdfs:comment "The operator insp:chosenAny indicates true, if any of the content templates referred to by its arguments were chosen."@en ;
  rdfs:comment "<xsd:boolean> = insp:chosenAny ( <insp:ContentTemplate> ... )"@en ;
  rdf:type fun:Function ;
  fun:resultType xsd:boolean ;
  fun:arityMin 1 ;
  fun:argumentTypes ( insp:ContentTemplate ) ;
  rdfs:comment "All arguments have type insp:ContentTemplate."@en
.

insp:chosenAnyFor
  rdfs:label "Chosen Any For Function"@en ;
  rdfs:comment "The operator insp:chosenAnyFor indicates true, if for the intent element instance given as first argument any of content templates referred to by its second and further arguments were chosen."@en ;
  rdfs:comment "<xsd:boolean> = insp:chosenAnyFor ( <intent element> <insp:ContentTemplate> ... )"@en ;
  rdf:type fun:Function ;
  fun:resultType xsd:boolean ;
  fun:arityMin 2 ;
  fun:argumentTypes ( rdfs:Resource insp:ContentTemplate ) ;
  rdfs:comment "The first argument is of type rdfs:Resource. It is referring to an element of the intent. The second and remaining arguments have type insp:ContentTemplate."@en
.

insp:chosenHandlingDomain
  rdfs:label "Chosen Handling Domain Property"@en ;
  rdfs:comment "The property insp:chosenHandlingDomain refers to a chosen target autonomous domain. The intent expression is generated from the intent specification to express the requirements for that autonomous domain."@en ;
  rdf:type rdf:Property ;
  rdfs:subPropertyOf met:metric
.

insp:chosenIntentHandler
  rdfs:label "Chosen Intent Handler Property"@en ;
  rdfs:comment "The property insp:chosenIntentHandler refers to the instance of an intent manager within the chosen target autonomous domain. The intent expression is generated from the intent specification to be sent to this intent manager instance."@en ;
  rdf:type rdf:Property ;
  rdfs:subPropertyOf met:metric 
.

insp:content
  rdfs:label "Content Property"@en ;
  rdfs:comment "The property insp:content assigns the statements represented by the content template. The node used in its range is the source of statements to be transferred into the intent expression. All statements in that node shall be transferred. If insp:content is used multiple times within a content template, their contributions are additive and the superset of statements is applied."@en ;
  rdf:type rdf:Property ;
  rdfs:domain insp:ContentTemplate
.

insp:contentUsing
  rdfs:label "Content Using Property"@en ;
  rdfs:comment "The property insp:contentUsing represents content that is expressed in accordance with vocabulary templates. If it is used as property of a content template and represents a choice regarding content to be used in an intent expression made by the process that assembles the intent. This content is chosen in accordance with available vocabulary according to the vocabulary template in its range."@en ;
  rdf:type rdf:Property ;
  rdfs:domain insp:ContentTemplate
.

insp:ContentTemplate
  rdfs:label "Content Template Class"@en ;
  rdfs:comment "Content templates are instances of class insp:ContentTemplate, which is a subclass of insp:Template."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf insp:Template
.

insp:contentUsing
  rdfs:label "Content Using Property"@en ;
  rdfs:comment "The property insp:contentUsing assigns content chosen according to a vocabulary template."@en ;
  rdf:type rdf:Property ;
  rdfs:domain insp:ContentTemplate ;
  rdfs:range insp:VocabularyTemplate
.

insp:intentHandlerVendor
  rdfs:label "Intent Handler Vendor Property"@en ;
  rdfs:comment "The property insp:intentHandlerVendor refers to the vendor of the intent manager that is chosen to be the handler of the Intent that is generated from the intent specification."@en ;
  rdf:type rdf:Property ;
  rdfs:subPropertyOf met:metric
.

insp:intentOwner
  rdfs:label "Intent Owner Property"@en ;
  rdfs:comment "The property insp:intentOwner refers to the intent manager that is assembling the intent from the intent specification."@en ;
  rdf:type rdf:Property ;
  rdfs:subPropertyOf met:metric
.

insp:intentOwnerDomain
  rdfs:label "Intent Owner Domain Property"@en ;
  rdfs:comment "The property insp:intentOwnerDomain refers to the autonomous domain of the intent manager that is assembling the intent from the intent specification."@en ;
  rdf:type rdf:Property ;
  rdfs:subPropertyOf met:metric
.

insp:intentOwnerVendor
  rdfs:label "Intent Owner Vendor Property"@en ;
  rdfs:comment "The property insp:intentOwnerVendor refers to the vendor of the intent manager that is assembling the intent from the intent specification."@en ;
  rdf:type rdf:Property ;
  rdfs:subPropertyOf met:metric
.

insp:IntentSpecification
  rdfs:label "Intent Specification Class"@en ;
  rdfs:comment "Intent specifications are instances of class insp:IntentSpecification. An intent is assembled in accordance to an intent specification by finding an intent expression that complies to all rules and constraints expressed by the intent specification."@en ;
  rdf:type rdfs:Class
.

insp:mandatory
  rdfs:label "Mandatory Property"@en ;
  rdfs:comment "The property insp:mandatory specifies a content template that represents a statement or sets of statements that must be included in an intent expression. Its range contains a content template instance of class insp:ContentTemplate. This content template determines the statements that must be used as substitute for the insp:mandatory statement in a conforming intent expression."@en ;
  rdf:type rdf:Property ;
  rdfs:range insp:ContentTemplate
.

insp:mandatoryIntent
  rdfs:label "mandatory Intent Property"@en ;
  rdfs:comment "The property insp:mandatoryIntent intent assigns intent expressions that must be used. This means an intent expression conforming to the intent specification must conform to this intent expression including all rules and dynamic content choices it allows."@en ;
  rdf:type rdf:Property ;
  rdfs:domain insp:IntentSpecification ;
  rdfs:range icm:Intent
.

insp:mandatorySpecification
  rdfs:label "Mandatory Specification Property"@en ;
  rdfs:comment "The property insp:mandatorySpecification expresses that an eligible intent expression must conform to the intent specification provided in its range. This expresses, that the rules and constraints of that intent specification are mandatory for follow. Multiple statements using insp:mandatorySpecification with the same subject are in a conjunction (AND). This means an assembled intent expression must conform to all mandatory intent specifications."@en ;
  rdf:type rdf:Property ;
  rdfs:domain insp:IntentSpecification ;
  rdfs:range insp:IntentSpecification
.

insp:ObjectTemplate
  rdfs:label "Object Template Class"@en ;
  rdfs:comment "An object template is an instance of class insp:ObjectTemplate, which is a subclass of insp:Template. Within intent specifications an object template can be used as substitute for any object within an intent expression."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf insp:Template
.

insp:option
  rdfs:label "Option Property"@en ;
  rdfs:comment "The property insp:option specifies a set of statements that can be used in an intent expression. The range of insp:option is a template of class insp:ContentTemplate. The statements and expressions of this content template would substitute the insp:option statement within a conforming intent expression if this option is chosen."@en ;
  rdf:type rdf:Property ;
  rdfs:range insp:ContentTemplate
.

insp:optionalIntent
  rdfs:label "Optional Intent Property"@en ;
  rdfs:comment "The property insp:optionalIntent assigns intent objects to an intent specification. An intent expression that resembles any of these intents conforms to the intent specification."@en ;
  rdf:type rdf:Property ;
  rdfs:domain insp:IntentSpecification ;
  rdfs:range icm:Intent
.

insp:optionalSpecification
  rdfs:label "Optional Specification Property"@en ;
  rdfs:comment "The property insp:optionalSpecification expresses that an intent expression can be assembled following the intent specifications provided in its range. Multiple statements using insp:optionalSpecification with the same subject are in a disjunction (OR). This means an intent expression conforms overall if it conforms to at least one and potentially several of the optional specifications."@en ;
  rdf:type rdf:Property ;
  rdfs:domain insp:IntentSpecification ;
  rdfs:range insp:IntentSpecification
.

insp:selectValues
  rdfs:label "Select Values Function"@en ;
  rdfs:comment "The abstract function insp:selectValues represents a container of values that can be chosen to substitute an object template. The first argument of insp:selectValues is a variable that represents the values to be chosen. The second and further arguments are conditions that use the variable in its first argument to express condition statements. Every value possible for the variable in the first argument according to the conditions is a member of the resulting container. The conditions are in a conjunction. This means, a value needs to satisfy all conditions to be included in the result container."@en ;
  rdfs:comment "<rdfs:Container> = insp:selectValues ( <rdfs:Resource> <log:Condition> ... )"@en ;
  rdf:type fun:Function ;
  fun:resultType rdfs:Container ;
  fun:arityMin 2 ;
  fun:argumentTypes ( rdfs:Resource log:Condition ) ;
  rdfs:comment "The first argument is any rdfs:Resource. The second and further arguments are log:Condition."@en 
.

insp:Template
  rdfs:label "Template Class"@en ;
  rdfs:comment "Templates are instances of subclasses of class insp:Template."@en ;
  rdf:type rdfs:Class
.

insp:templateType
  rdfs:label "Template Type Property"@en ;
  rdfs:comment "The property insp:templateType specifies what type of object an object template instance is representing and substituting in an intent expression that conforms to the intent specification."@en ;
  rdf:type rdf:Property ;
  rdfs:domain insp:ObjectTemplate
.

insp:usedVocabularyFor
  rdfs:label "Used Vocabulary For Function"@en ;
  rdfs:comment "The function insp:usedVocabularyFor indicates true, if for expressing the intent element referred to by the first argument all vocabulary is used specified in any of the remaining arguments. The second and remaining arguments are containers with members that refer to distinct elements of intent expression vocabulary."@en ;
  rdfs:comment "<xsd:boolean> = insp:usedVocabularyFor ( <intent element> <rdfs:Container> ... )"@en ;
  rdf:type fun:Function ;
  fun:resultType xsd:boolean ;
  fun:arityMin 2 ;
  fun:argumentTypes ( rdfs:Resource rdfs:Container ) ;
  rdfs:comment "The first argument is of type rdfs:Resource. It is referring to an element of the intent. The second and remaining arguments have type rdfs:Container. They define the set of vocabulary the function is checking against."@en 
.

insp:valueSelected
  rdfs:label "Value Selected Function"@en ;
  rdfs:comment "The operator insp:valueSelected indicates true, if for the object template referred to by the first argument, the chosen value is a member of the containers provided as second or remaining arguments."@en ;
  rdfs:comment "<xsd:boolean> = insp:valueSelected ( <insp:ObjectTemplate> <rdfs:Container> ... )"@en ;
  rdf:type fun:Function ;
  fun:resultType xsd:boolean ;
  fun:arityMin 2 ;
  fun:argumentTypes ( insp:ObjectTemplate insp:ContentTemplate ) ; 
  rdfs:comment "The first argument is of type insp:ObjectTemplate. The second and remaining arguments have type insp:ContentTemplate."@en 
.

insp:valueSelectedFor
  rdfs:label "Value Selected For Function"@en ;
  rdfs:comment "The operator insp:valueSelectedFor indicates true, if certain values were chosen for the combination of an intent element and object template. The intent element to be considered is provided by the first argument and the object template is referred to by the second argument. The values to be checked are members of the containers provided by the third or remaining arguments."@en ;
  rdfs:comment "<xsd:boolean> = insp:valueSelectedFor ( <intent element> <insp:ObjectTemplate> <rdfs:Container> ... )"@en ;
  rdf:type fun:Function ;
  fun:resultType xsd:boolean ;
  fun:arityMin 3 ; 
  fun:argumentTypes ( rdfs:Resource insp:ObjectTemplate insp:ContentTemplate ) ;
  rdfs:comment "The first argument is of type rdfs:Resource. It is referring to an element of the intent. The second argument is of type insp:ObjectTemplate. The third and remaining arguments have type insp:ContentTemplate."@en 
.

insp:Vocabulary
  rdfs:label "Intent Specification Vocabulary"@en ;
  rdfs:comment "The object insp:Vocabulary is a container of all model elements."@en ;
  rdf:type rdfs:Container ;
  rdfs:member insp:allowedValues ,
              insp:alternative ,
              insp:applicableIf ,
              insp:applicableIfNot ,
              insp:availableVocabulary ,
              insp:chosenAll ,
              insp:chosenAllFor ,
              insp:chosenAny ,
              insp:chosenAnyFor ,
              insp:chosenHandlingDomain ,
              insp:chosenIntentHandler ,
              insp:content ,
              insp:contentUsing ,
              insp:ContentTemplate ,
              insp:contentUsing ,
              insp:intentHandlerVendor ,
              insp:intentOwner ,
              insp:intentOwnerDomain ,
              insp:intentOwnerVendor ,
              insp:IntentSpecification ,
              insp:mandatory ,
              insp:mandatoryIntent ,
              insp:mandatorySpecification ,
              insp:ObjectTemplate ,
              insp:option ,
              insp:optionalIntent ,
              insp:optionalSpecification ,
              insp:selectValues ,
              insp:Template ,
              insp:templateType ,
              insp:usedVocabularyFor ,
              insp:valueSelected ,
              insp:valueSelectedFor ,
              insp:VocabularyTemplate
.

insp:VocabularyTemplate
  rdfs:label "Vocabulary Template Class"@en ;
  rdfs:comment "A vocabulary template is an instance of class insp:VocabularyTemplate, which is a subclass of insp:Template. A vocabulary template is also a subclass of imo:Vocabulary, which is a subclass of rdfs:Container."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf insp:Template ;
  rdfs:subClassOf imo:Vocabulary
.
