@prefix icm:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentCommonModel/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/tio-instance/TC001/intent> a icm:Intent .
<http://example.org/tio-instance/TC001/exp-del> a icm:DeliveryExpectation ;
  icm:target <http://example.org/tio-instance/TC001/tgt> ;
  rdfs:comment "Establish a 5G slice service."@en .
