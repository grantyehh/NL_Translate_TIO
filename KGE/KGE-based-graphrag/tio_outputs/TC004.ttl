@prefix icm:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentCommonModel/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/tio-instance/TC004/intent> a icm:Intent ;
  icm:context <http://example.org/tio-instance/TC004/ctx> .
<http://example.org/tio-instance/TC004/ctx> a icm:Context ;
  rdfs:comment "Weekday working hours (08:00-18:00)."@en .
<http://example.org/tio-instance/TC004/exp-prop> a icm:PropertyExpectation ;
  icm:target <http://example.org/tio-instance/TC004/tgt> ;
  rdfs:comment "Bandwidth priority should be set to highest."@en .
<http://example.org/tio-instance/TC004/tgt> a icm:Target ;
  rdfs:comment "Office building bandwidth."@en .