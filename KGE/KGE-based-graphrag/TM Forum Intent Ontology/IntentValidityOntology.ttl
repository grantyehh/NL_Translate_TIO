@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix t:    <http://www.w3.org/2006/time#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

<http://tio.models.tmforum.org/tio/v3.6.0/IntentValidityOntology/>
  rdf:type imo:IntentExtensionModel ;
  rdfs:label "Intent Validity Model"@en ;
  rdfs:Comment "The intent validity modelprovides the vocabulary for specifying the detailed conditions of validity within the intent expression."@en ;
  dct:title "Intent Validity Model"@en ;
  dct:description "The intent validity modelprovides the vocabulary for specifying the detailed conditions of validity within the intent expression."@en ;
  dct:subject "intent validity"@en ,
              "intent expression"@en ;
  dct:identifier <http://tio.models.tmforum.org/tio/v3.6.0/IntentValidityOntology/> ;
  # dct:isPartOf <http://tio.models.tmforum.org/tio/v3.6.0/TMForumIntentOntology> ;
  dct:replaces <http://tio.models.tmforum.org/tio/v3.5.0/IntentValidityOntology/> ;
  dct:contributor <mailto:joerg.niemoeller@ericsson.com> ;
  dct:created "2024-10-15"^^xsd:date ;
