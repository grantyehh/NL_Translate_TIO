  rdfs:seeAlso <https://www.tmforum.org/resources/introductory-guide/tr291a-intent-validity-intent-extension-model-v3-6-0/> ;
  rdfs:seeAlso <https://www.tmforum.org/resources/standard/ig1358-intent-based-operation-user-guide-v1-0-0/> ;
  skos:changeNote "2024-10-15 - initial draft of turtle file"@en 
.

iv:isValid
  rdfs:label "Is Valid Property"@en ;
  rdfs:comment "The property iv:isValid is used to state the validity status of its object. It is used in intent reports. This means it states the validity at the time of report generation. The range of iv:isValid contains a Boolean literal value. It is set to true, if the object is valid and false if not."@en ;
  rdf:type rdf:Property ;
  rdfs:range xsd:Boolean
.

iv:sameValidityAs
  rdfs:label "Same Validity As Property"@en ;
  rdfs:comment "The property iv:sameValidityAs specifies that the validity of the subject shall be the same as the validity of the object."@en ;
  rdf:type rdf:Property 
.

iv:validIf
  rdfs:label "Valid If Property"@en ;
  rdfs:comment "The property iv:validIf assigns validity context to objects."@en ;
  rdf:type rdf:Property ;
  rdf:subPropertyOf: icm:context ;
  rdfs:range iv:Validity
.

iv:Validity
  rdfs:label "Validty Context Class"@en ;
  rdfs:comment "The class iv:Validity is a subclass of icm:Context. It represents and determines the validity of resources it is associated with using the property iv:validIf ."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf icm:Context ;
  rdfs:subClassOf t:TemporalEntity
.

iv:ValidityChange
  rdfs:label "Validity Change Event"@en ;
  rdfs:comment "The class iv:ValidityChange is a subclass of imo:intentHandlingEvent and represents events issued if the validity status of a resource is changing."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf imo:IntentHandlingEvent
.

iv:ValidityChangeInvalid
  rdfs:label "Change to Invalid Event"@en ;
  rdfs:comment "The class iv:ValidityChange is a subclass of iv:ValidityChange and represents events issued if the validity status of a resource is changing to invalid."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf iv:ValidityChange
.

iv:ValidityChangeValid
  rdfs:label "Change to Valid Event"@en ;
  rdfs:comment "The class iv:ValidityChange is a subclass of iv:ValidityChange and represents events issued if the validity status of a resource is changing to valid."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf iv:ValidityChange
.

iv:validityOf
  rdfs:label "Validity Of Function"@en ;
  rdfs:comment "The property iv:validityOf is a function that states the validity status of its arguments. If all arguments are valid, then the result of iv:validityOf is true, if any resource used as argument is not valid the result of iv:validityOf is false."@en ;
  rdf:type fun:Function ;
  fun:resultType xsd:Boolean ;
  fun:argumentTypes ( rdf:Resource )
.

iv:ValidityReport
  rdfs:label "Validity Report Class"@en ;
  rdfs:comment "Instances of class iv:ValidityReport are used in intent reports to provide reporting about validity context."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf icm:ContextReport
.

iv:ValidityReportingExpectation
  rdfs:label "Validity Reporting Expectation Class"@en ;
  rdfs:comment "A validity reporting expectation is an instance of class iv:ValidityReportingExpectation within an intent. A validity reporting expectation is chosen to request an intent report, if the intent report shall explicitly state the validity of intent elements."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf icm:ReportingExpectation
.

iv:validityStatus
  rdfs:label "Validity Status Class"@en ;
  rdfs:comment "If an intent report is generated for a validity reporting expectation it can contain iv:validityStatus properties associated with dedicated reports for intent elements. It provides the validity status at the time of report generation and regarding the intent element referred to with the property icm:about. The property iv:validityStatus assigns a boolean value. The value true means the intent element is valid and false means invalid."@en ;
  rdf:type rdf:Class ;
  rdfs:range xsd:boolean
.

iv:valueIfNotValid
  rdfs:label "Value If Not Valid Property"@en ;
  rdfs:comment "The property iv:valueIfNotValid allows specifying a function result that shall be provided as a default for invalid functions."@en ;
  rdf:type rdf:Property 
.

iv:Vocabulary
  rdfs:label "Validity Model Vocabulary"@en ;
  rdfs:comment "The object iv:Vocabulary is a container of all model elements."@en ;
  rdf:type rdfs:Container ;
  rdfs:member iv:isValid ,
              iv:sameValidityAs ,
              iv:validIf ,
              iv:Validity ,
              iv:ValidityChange ,
              iv:ValidityChangeInvalid ,
              iv:ValidityChangeValid ,
              iv:validityOf ,
              iv:ValidityReport ,
              iv:ValidityReportingExpectation ,
              iv:validityStatus ,
              iv:valueIfNotValid 
.





