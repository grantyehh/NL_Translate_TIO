# Intent Guarantee Ontology v3.6.0

@prefix ig:   <http://tio.models.tmforum.org/tio/v3.6.0/IntentGuaranteeOntology/> .
@prefix icm:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentCommonModel/> .
@prefix imo:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentManagementOntology/> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix t:    <http://www.w3.org/2006/time#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

<http://tio.models.tmforum.org/tio/v3.6.0/IntentGuaranteeOntology/>
  rdf:type imo:IntentExtensionModel ;
  rdfs:label "Preference Of Intent Handling Outcomes Model"@en ;
  rdfs:Comment "The Intent Guarantee model extends the vocabulary of the TM Forum Intent Ontology (TIO) to support the request for guarantees that are future looking and that are statements of enduring compliance."@en ;
  dct:title "Preference Of Intent Handling Outcomes Model"@en ;
  dct:description "The Intent Guarantee model extends the vocabulary of the TM Forum Intent Ontology (TIO) to support the request for guarantees that are future looking and that are statements of enduring compliance."@en ;
  dct:subject "intent guarantee"@en ,
              "intent expression"@en ;
  dct:identifier <http://tio.models.tmforum.org/tio/v3.6.0/IntentGuaranteeOntology/> ;
  # dct:isPartOf <http://tio.models.tmforum.org/tio/v3.6.0/TMForumIntentOntology> ;
  dct:replaces <http://tio.models.tmforum.org/tio/v3.5.0/IntentGuaranteeOntology/> ;
  dct:contributor <mailto:joerg.niemoeller@ericsson.com> ;
  dct:created "2024-10-16"^^xsd:date ;
  dct:creator <mailto:joerg.niemoeller@ericsson.com> ;
  dct:license <http://www.apache.org/licenses/LICENSE-2.0> ;
  dct:license <https://github.com/tmforum-apis/Intent_Repository> ;
  dct:modified "2024-10-16"^^xsd:date ;
  dct:rights "Copyright © 2024 TM Forum"@en ;
  dct:rightHolder "TM Forum" ;
  dct:publisher "TM Forum" ;
  rdfs:seeAlso <https://www.tmforum.org/resources/how-to-guide/ig1253-intent-in-autonomous-networks-v1-3-0/> ;
  rdfs:seeAlso <https://www.tmforum.org/resources/introductory-guide/tr291h-intent-guarantee-intent-extension-model-v3-6-0/> ;
  rdfs:seeAlso <https://www.tmforum.org/resources/standard/ig1358-intent-based-operation-user-guide-v1-0-0/> ;
  skos:changeNote "2024-10-16 - initial draft of turtle file"@en 
.

ig:GuaranteeAccepted
  rdfs:label "Guarantee Accepted Event Class"@en ;
  rdfs:comment "The class ig:GuaranteeAccepted specifies an event. The meaning of the event is that the intent handler has concluded that it is capable of issuing a requested guarantee for the next guarantee period. The guarantee target state is GuaranteeStateCompliant."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf imo:Event
.

ig:confidenceLevel
  rdfs:label "Confidence Level Property"@en ;
  rdfs:comment "The property ig:confidenceLevel specifies a required, predicted or real (measured) confidence/probability level, as a value between 0-1 (percentage). If not specified the confidence is assumed to be 1 (100%)."@en ;
  rdf:type rdf:Property ;
  rdfs:range xsd:decimal
.

ig:ConfidenceLevelNotObtainable
  rdfs:label "Confidence Level Not Obtainable Reason Class"@en ;
  rdfs:comment "The class ig:Complies specifies a reason for rejection of a guarantee. The requested confidence level is not possible to reach for during the guarantee period, according to predictions."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf icm:Reason
.

ig:ConfidenceLevelNotReached
  rdfs:label "Confidence Level Not Reached Reason Class"@en ;
  rdfs:comment "The class ig:Complies specifies a reason for degradation of a guarantee. The requested confidence level was not reached during the evaluation window."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf icm:Reason
.

ig:ConflictingGuarantees
  rdfs:label "Conflicting Guarantees Reason Class"@en ;
  rdfs:comment "The class ig:Complies specifies a reason for rejection of a guarantee. A requirement is associated with more than one guarantee context, of which more than one is valid at some point in time during the upcoming guarantee period."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf icm:Reason
.

ig:Guarantee
  rdfs:label "Guarantee Context Class"@en ;
  rdfs:comment "The class Guarantee is a context that, when associated with requirements (objects of type icm:Expectation, icm:Condition and icm:Intent), modifies the status of those requirements to guaranteed."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf icm:Context
.

ig:guaranteePeriod
  rdfs:label "Guarantee Period Property"@en ;
  rdfs:comment "The property ig:guaranteePeriod specifies the duration of guarantee periods, in ISO8601 format. If not specified in a guarantee reporting expectation the guarantee period is the entire life-span of the associated intent, which is generally indefinite unless limited by other vocabulary."@en ;
  rdf:type rdf:Property ;
  rdfs:domain ig:GuaranteeReportingExpectation ;
  rdfs:range xsd:duration
.

ig:GuaranteePeriodUpdate
  rdfs:label "Guarantee Period Update Event Class"@en ;
  rdfs:comment "The class ig:GuaranteePeriodUpdate specifies an event. The meaning of the event is that a new evaluation and planning phase has been initiated as a result of periodic updating or the end of the previous guarantee period. The guarantee target state is either GuaranteeStateCompliant or GuaranteeStateDegraded, depending on the outcome."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf imo:Event
.

ig:guaranteePeriodUpdateInterval
  rdfs:label "Guarantee Period Update Interval Property"@en ;
  rdfs:comment "The property ig:guaranteePeriodUpdateInterval specifies the interval of re-evaluation and planning of guarantee periods, in ISO8601 format. If not specified in a guarantee reporting expectation the guarantee period update interval is the same as the guarantee period."@en ;
  rdf:type rdf:Property ;
  rdfs:domain ig:GuaranteeReportingExpectation ;
  rdfs:range xsd:duration
.

ig:GuaranteePeriodNotObtainable
  rdfs:label "Guarantee Period Not Obtainable Reason Class"@en ;
  rdfs:comment "The class ig:Complies specifies a reason for rejection of a guarantee. It is not possible to guarantee the requirement during the requested guarantee period."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf icm:Reason
.

ig:GuaranteePeriodTooLong
  rdfs:label "Guarantee Period Too Long Reason Class"@en ;
  rdfs:comment "The class ig:Complies specifies an reason for rejection of a guarantee. The requested guarantee period is too long for the intent handler to accurately predict and plan for the guarantee, this is a result of limitations in implementation."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf  icm:Reason
.

ig:GuaranteePeriodUpdateIntervalTooLong
  rdfs:label "Guarantee Period Update Interval Too Long Reason Class"@en ;
  rdfs:comment "The class ig:GuaranteePeriodUpdateIntervalTooLong specifies a warning. The requested guarantee period update interval is longer than the guarantee period. The result is that it is void and the guarantee period and update interval is the same."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf icm:Reason
.

ig:GuaranteeRejected
  rdfs:label "Guarantee Rejected Event Class"@en ;
  rdfs:comment "The class ig:GuaranteeRejected specifies an event. The meaning of the event is that the intent handler has concluded that it is not capable of issuing a requested guarantee. The guarantee target state is ig:GuaranteeStateRejected."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf icm:Event
.

ig:GuaranteeReportingExpectation
  rdfs:label "Guarantee Reporting Expectation Class"@en ;
  rdfs:comment "The class ig:GuaranteeReportingExpectation specifies a reporting expectation for guarantees and is used to configure a specific guarantee period and conditions for when to issue reports related to guarantees."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf  icm:ReportingExpectation
.

ig:GuaranteeStateCompliant
  rdfs:label "Guarantee State Compliant Class"@en ;
  rdfs:comment "The class ig:GuaratneeStateCompliant specifies a state. The meaning of the state is that the intent handler has concluded that it's capable of delivering the guarantee for the next guarantee period. Possible events transitioning from this state are imo:UpdateReceived and ig:GuaranteePeriodUpdate."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf ig:State
.

ig:GuaranteeStateDegraded
  rdfs:label "Guarantee State Degraded Class"@en ;
  rdfs:comment "The class ig:GuaratneeStateDegraded specifies a state. The meaning of the state is that the intent handler has concluded that it's not capable of delivering the guarantee for the next guarantee period. Possible events transitioning from this state are imo:UpdateReceived and ig:GuaranteePeriodUpdate."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf ig:State
.

ig:hasGuarantee
  rdfs:label "Has Guarantee Property"@en ;
  rdfs:comment "The property ig:hasGuarantee is used to associate a guarantee context with a requirement (objects of type icm:Expectation, icm:Condition and icm:Intent)."@en ;
  rdf:type rdf:Property ;
  rdfs:range ig:Guarantee
.

ig:State
  rdfs:label "State Class"@en ;
  rdfs:comment "The class ig:State is a base-class of Guarantee states."@en ;
  rdf:type rdfs:Class
.

ig:state
  rdfs:label "State Property"@en ;
  rdfs:comment "The property ig:state specifies the state of a guarantee."@en ;
  rdf:type rdf:Property ;
  rdfs:domain ig:GuaranteeReport ;
  rdfs:range ig:State
.

ig:until
  rdfs:label "Until Property"@en ;
  rdfs:comment "The property ig:until specifies the expiry date and time of a guarantee period, in ISO8601 format."@en ;
  rdf:type rdf:Property ;
  rdfs:domain ig:GuaranteeReport ;
  rdfs:range xsd:dateTime
.

ig:Vocabulary
  rdfs:label "Guarantee Vocabulary"@en ;
  rdfs:comment "The object ig:Vocabulary is a container of all model elements."@en ;
  rdf:type rdfs:Container ;
  rdfs:member ig:GuaranteeAccepted ,
              ig:confidenceLevel ,
              ig:ConfidenceLevelNotObtainable ,
              ig:ConfidenceLevelNotReached ,
              ig:ConflictingGuarantees ,
              ig:Guarantee ,
              ig:guaranteePeriod ,
              ig:GuaranteePeriodUpdate ,
              ig:guaranteePeriodUpdateInterval ,
              ig:GuaranteePeriodNotObtainable ,
              ig:GuaranteePeriodTooLong ,
              ig:GuaranteePeriodUpdateIntervalTooLong ,
              ig:GuaranteeRejected ,
              ig:GuaranteeReportingExpectation ,
              ig:GuaranteeStateCompliant ,
              ig:GuaranteeStateDegraded ,
              ig:hasGuarantee ,
              ig:State ,
              ig:state ,
              ig:until 
.

