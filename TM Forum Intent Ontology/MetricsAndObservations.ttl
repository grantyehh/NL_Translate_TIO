met:lastObserved
  rdfs:label "Last Observed Function"@en ;
  rdfs:comment "The function met:lastObserved refers to the newest individual observation created for the metrics that are provided as function arguments. For example, it refers to latest measurement obtained for a latency."@en ;
  rdf:type fun:function ;
  fun:resultType met:Observation ;
  fun:arityMin 1 ;
  fun:argumentTypes ( rdfs:Metric )
.

met:lastValue
  rdfs:label "Last Value Function"@en ;
  rdfs:comment "The function met:lastValue refers to the newest observed value for a metric and provides the value as result."@en ;
  rdf:type fun:function ;
  fun:resultType rdf:Resource ;
  fun:arityMin 1 ;
  fun:argumentTypes ( rdfs:Metric )
.

met:metric
  rdfs:label "Metric Property"@en ;
  rdfs:comment "Sub-properties of  met:Metric represent observable and measurable items."@en ;
  rdf:type rdf:Property
.

met:Observation
  rdfs:label "Observation Class"@en ;
  rdfs:comment "An observation is a distinct value or fact that was observed or measured for a metric. An observation is represented by an individual of class met:Observation. They represent a measured or otherwise observed fact about a resource."@en ;
  rdf:type rdfs:Class
.

met:observed
  rdfs:label "Observed Property"@en ;
  rdfs:comment "The property met:observed can be used to assign an instance of class met:Observation to other objects."@en ;
  rdf:type rdf:Property ;
  rdfs:range met:Observation
.

met:observedMetric
  rdfs:label "Observed Metric Property"@en ;
  rdfs:comment "The property met:observedMetric states what was observed by an observation. This refers to a met:metric property that identifies a metric."@en ;
  rdf:type rdf:Property ;
  rdfs:domain met:Observation ;
  rdfs:range met:Metric
.

met:observedValue
  rdfs:label "Observed Value Function"@en ;
  rdfs:comment "The function met:observedValue refers to the value of an individual observation and provides this value as function result."@en ;
  rdf:type fun:function ;
  fun:resultType rdf:Resource ;
  fun:arityMin 1 ;  
  fun:arityMax 1 ;  
  fun:argumentTypes ( met:Observation ) 
.

met:obtainedAt
  rdfs:label "Obtained At Function"@en ;
  rdfs:comment "The property met:obtainedAt states the point in time when the observation was obtained and the observation individual was created in the knowledge base."@en ;
  rdf:type rdf:Property ;
  rdfs:domain met:Observation ;
.

met:Vocabulary
  rdfs:label "Metrics and Observation Vocabulary"@en ;
  rdfs:comment "The object met:Vocabulary is a container of all model elements."@en ;
  rdf:type rdfs:Container ;
  rdfs:member met:lastObserved ,
              met:lastValue ,
              met:metric ,
              met:Observation ,
              met:observed ,
              met:observedMetric ,
              met:observedValue ,
              met:obtainedAt
.

