<http://tio.models.tmforum.org/tio/v3.6.0/MetricsAndObservations/>
  rdf:type imo:BaseOntologyModel ;
  rdfs:label "Metrics And Observations Ontology"@en ;
  rdfs:Comment "This ontology model introduces metrics and observations and specifies classes, properties and functions for defining and managing them."@en ;
  dct:title "Metrics And Observations Ontology"@en ;
  dct:description "This ontology model introduces metrics and observations and specifies classes, properties and functions for defining and managing them."@en ;
  dct:subject "metrics definition"@en ,
              "measurements"@en ,
              "intent expression"@en ;
  dct:identifier <http://tio.models.tmforum.org/tio/v3.6.0/MetricsAndObservations/> ;
  # dct:isPartOf <http://tio.models.tmforum.org/tio/v3.6.0/TMForumIntentOntology> ;
