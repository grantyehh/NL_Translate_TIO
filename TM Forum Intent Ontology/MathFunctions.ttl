# Mathematical Functions Definition and Collection Ontology version 3.6.0

@prefix mf:   <http://tio.models.tmforum.org/tio/v3.6.0/MathFunctions> .
@prefix fun:  <http://tio.models.tmforum.org/tio/v3.6.0/FunctionOntology/> .
@prefix quan: <http://tio.models.tmforum.org/tio/v3.6.0/QuantityOntology/> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix t:    <http://www.w3.org/2006/time#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

<http://tio.models.tmforum.org/tio/v3.6.0/MathFunctions/>
  rdf:type imo:BaseOntologyModel ;
  rdfs:label "Mathematical Functions Definition and Collection Ontology"@en ;
  rdfs:Comment "This ontology model defines a set of mathematical functions and vocabulary to manage value ranges and composite functions."@en ;
  dct:title "Mathematical Functions Definition and Collection Ontology"@en ;
  dct:description "This ontology model defines a set of mathematical functions and vocabulary to manage value ranges and composite functions."@en ;
  dct:subject "functions"@en ,
              "mathematical functions"@en ,
              "intent expression"@en ;
  dct:identifier <http://tio.models.tmforum.org/tio/v3.6.0/MathFunctions/> ;
  # dct:isPartOf <http://tio.models.tmforum.org/tio/v3.6.0/TMForumIntentOntology> ;
  dct:replaces <http://tio.models.tmforum.org/tio/v3.5.0/MathFunctions/> ;
  dct:contributor <mailto:joerg.niemoeller@ericsson.com> ;
  dct:created "2024-10-09"^^xsd:date ;
  dct:creator <mailto:joerg.niemoeller@ericsson.com> ;
