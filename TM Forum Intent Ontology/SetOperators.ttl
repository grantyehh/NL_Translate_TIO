# Set Operators Ontology version 3.6.0

@prefix set:  <http://tio.models.tmforum.org/tio/v3.6.0/SetOperators/> .
@prefix fun:  <http://tio.models.tmforum.org/tio/v3.6.0/FunctionOntology/> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix t:    <http://www.w3.org/2006/time#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

<http://tio.models.tmforum.org/tio/v3.6.0/SetOperators/>
  rdf:type imo:BaseOntologyModel ;
  rdfs:label "Set Operators Ontology"@en ;
  rdfs:Comment "This ontology model introduces set operators. They allow to contruct sets and draw inference from sets when used in condition expressions."@en ;
  dct:title "SetOperators Ontology"@en ;
  dct:description "This ontology model introduces set operators. They allow to contruct sets and draw inference from sets when used in condition expressions."@en ;
  dct:subject "set operators"@en ,
              "condition expression"@en ,
              "intent expression"@en ;
  dct:identifier <http://tio.models.tmforum.org/tio/v3.6.0/SetOperators/> ;
  # dct:isPartOf <http://tio.models.tmforum.org/tio/v3.6.0/TMForumIntentOntology> ;
  dct:replaces <http://tio.models.tmforum.org/tio/v3.5.0/SetOperators/> ;
  dct:contributor <mailto:joerg.niemoeller@ericsson.com> ;
  dct:created "2024-10-09"^^xsd:date ;
  dct:creator <mailto:joerg.niemoeller@ericsson.com> ;
  dct:license <http://www.apache.org/licenses/LICENSE-2.0> ;
  dct:license <https://github.com/tmforum-apis/Intent_Repository> ;
  dct:modified "2024-10-09"^^xsd:date ;
  dct:rights "Copyright © 2024 TM Forum"@en ;
  dct:rightHolder "TM Forum" ;
  dct:publisher "TM Forum" ;
  rdfs:seeAlso <https://www.tmforum.org/resources/how-to-guide/ig1253-intent-in-autonomous-networks-v1-3-0/> ;
  rdfs:seeAlso <https://www.tmforum.org/resources/introductory-guide/tr292f-set-operators-v3-6-0/> ;
  rdfs:seeAlso <https://www.tmforum.org/resources/standard/ig1358-intent-based-operation-user-guide-v1-0-0/> ;
  skos:changeNote "2024-10-09 - initial draft of turtle file"@en 
.

set:difference
  rdfs:label "Diffrence Function"@en ;
  rdfs:comment "The function set:difference represents a container of all members of the first argument container, which are not members of the other given containers as well. If no argument is given, the resulting container is empty. If only one argument is given, the resulting container is identical to the argument."@en ;
  rdf:type fun:Function ;
  fun:resultType rdfs:Container ;
  fun:argumentTypes ( rdfs:Container )
.

set:elementOf
  rdfs:label "Element Of Function"@en ;
  rdfs:comment "The function set:elementOf represents the result of an evaluation. It assumes the boolean type result value true, if the resource given in the first argument is a member of all the containers given by the remaining arguments."@en ;
  rdf:type fun:Function ;
  fun:resultType xsd:boolean ;
  fun:arityMin 2 ;
  fun:argumentTypes ( rdfs:Resource rdfs:Container )
.

set:empty
  rdfs:label "Empty Function"@en ;
  rdfs:comment "The function set:empty represents the result of an evaluation. It assumes the boolean type result value true, if none of the containers given as arguments has any members."@en ;
  rdf:type fun:Function ;
  fun:resultType xsd:boolean ;
  fun:arityMin 1 ;
  fun:argumentTypes ( rdfs:Container )
.

set:forAll
  rdfs:label "For All Function"@en ;
  rdfs:comment "The function set:forAll has at least three arguments. The first argument represents any individual member from the container provided in the second argument. The third and all following arguments are resources with Boolean value. This can for example be a function that evaluates to a Boolean result. The function set:forAll has a Boolean type result directly derived from the third argument. The set:forAll function replicates the evaluation of the third argument for every member of the second argument. This allows to express that a condition set by the third argument needs to be met by every member of the provided container. The first argument is a resource use do represent individual members of the container. It can be used in the expression of the condition or evaluation specified by the third argument."@en ;
  rdf:type fun:Function ;
  fun:resultType xsd:boolean ;
  fun:arityMin 3 ;
  fun:argumentTypes ( rdf:Resource rdfs:Container rdf:Resource)
.

set:includedIn
  rdfs:label "Included In Function"@en ;
  rdfs:comment "The function set:includedIn represents the result of an evaluation. It assumes the boolean type result value true, if all members of the container in the first argument are also members of each container given by the remaining arguments."@en ;
  rdf:type fun:Function ;
  fun:resultType xsd:boolean ;
  fun:arityMin 2 ;
  fun:argumentTypes ( rdfs:Container )
.

set:intersection
  rdfs:label "Intersection Function"@en ;
  rdfs:comment "The function set:intersection represents a container of only those resources that are members of all containers specified in the arguments. If no arguments are given, the resulting container is empty. If only one argument is given, the resulting container is identical to the argument."@en ;
  rdf:type fun:Function ;
  fun:resultType rdfs:Container ;
  fun:argumentTypes ( rdfs:Container )
.

set:intersectsWith
  rdfs:label "Intersects With Function"@en ;
  rdfs:comment "The function set:intersectsWith represents the result of an evaluation. It assumes the boolean type result value true, if there are member objects in the first argument container that are also members in all other containers given as arguments."@en ;
  rdf:type fun:Function ;
  fun:resultType xsd:boolean ;
  fun:arityMin 2 ; 
  fun:argumentTypes ( rdfs:Container ) 
.

set:isMember
  rdfs:label "Is Member Function"@en ;
  rdfs:comment "The function set:isMember has at least two arguments. It provides the result true if the resource provided as first argument is a member of any container provided by the remaining arguments."@en ;
  rdf:type fun:Function ;
  fun:resultType xsd:boolean ;
  fun:arityMin 2 ; 
  fun:argumentTypes ( rdf:Resource rdfs:Container ) 
.

set:membersAfter
  rdfs:label "members After Function"@en ;
  rdfs:comment "The function set:membersAfter represents the result of a time based container member filtering. The first parameter refers to the property of a member that assigns a time-stamp to a member object. This is the timestamp to be used in the evaluation of this function. The second parameter specifies a point in time expressed as individual of the class t:Instant defined in the time ontology in OWL [owltime]. The third and all remaining parameters are containers. The function provides a container as result. The members of this result container are members of the union of all containers provided as parameters, which meet the condition that their time stamp is after the time stamp provided as second parameter. The property provided as first parameter is the one used to evaluate the condition. This property needs to be used for a member of the input containers for the member object to be considered in the evaluation and included in the result."@en ;
  rdf:type fun:Function ;
  fun:resultType rdfs:Container ;
  fun:arityMin 3 ;
  fun:argumentTypes ( rdf:Property t:Instance rdfs:Container )
.

set:membersBefore
  rdfs:label "membersBefore Function"@en ;
  rdfs:comment "The function set:membersBefore represents the result of a time based container member filtering. The first parameter refers to the property of a member that assigns a time-stamp to a member object. This is the timestamp to be used in the evaluation of this function. The second parameter specifies a point in time expressed as individual of the class t:Instant defined in the time ontology in OWL [owltime]. The third and all remaining parameters are containers. The function provides a container as result. The members of this result container are members of the union of all containers provided as parameters, which meet the condition that their time stamp is before the time stamp provided as second parameter. The property provided as first parameter is the one used to evaluate the condition. This property needs to be used for a member of the input containers for the member object to be considered in the evaluation and included in the result."@en ;
  rdf:type fun:Function ;
  fun:resultType rdfs:Container ;
  fun:arityMin 3 ;
  fun:argumentTypes ( rdf:Property t:Instance rdfs:Container ) 
.

set:membersSameTime
  rdfs:label "Members Same Time Function"@en ;
  rdfs:comment "The function set:membersSameTime represents the result of a time based container member filtering. The first parameter refers to the property of a member that assigns a time-stamp to a member object. This is the timestamp to be used in the evaluation of this function. The second parameter specifies a point in time expressed as individual of the class t:Instant defined in the time ontology in OWL [owltime]. The third and all remaining parameters are containers. The function provides a container as result. The members of this result container are members of the union of all containers provided as parameters, which meet the condition that their time-stamp shows the same time as the time-stamp provided as second parameter. The property provided as first parameter is the one used to evaluate the condition. This property needs to be used for a member of the input containers for the member object to be considered in the evaluation and included in the result."@en ;
  rdf:type fun:Function ;
  fun:resultType rdfs:Container ;
  fun:arityMin 3 ;
  fun:argumentTypes ( rdf:Property t:Instance rdfs:Container )
.

set:membersWhile
  rdfs:label "Members While Function"@en ;
  rdfs:comment "The function set:membersWhile represents the result of a time based container member filtering. The first parameter refers to the property of a member that assigns a time-stamp to a member object. This is the time-stamp to be used in the evaluation of this function. The second parameter specifies time interval in time expressed as individual of the class t:Interval defined in the time ontology in OWL [owltime]. The third and all remaining parameters are containers. The function provides a container as result. The members of this result container are members of the union of all containers provided as parameters, which meet the condition that their time-stamp lies within the time interval provided as second parameter. The property provided as first parameter is the one used to evaluate the condition. This property needs to be used for a member of the input containers for the member object to be considered in the evaluation and included in the result."@en ;
  rdf:type fun:Function ;
  fun:resultType rdfs:Container ;
  fun:arityMin 3 ;
  fun:argumentTypes ( rdf:Property t:Interval rdfs:Container )
.

set:newestMember
  rdfs:label "Newest Member Function"@en ;
  rdfs:comment "The function set:newestMember selects the newest member of the container according to a time-stamp property of the member object. The first parameter refers to the property of a member that assigns a time-stamp. This is the time-stamp to be used in the evaluation of this function. The third and all remaining parameters are containers. The function provides the resource as result that is the newest member object within the union of all containers provided as parameters as indicated by the property of the member object that was specified as first function parameter."@en ;
  rdf:type fun:Function ;
  fun:resultType rdf:Resource ;
  fun:arityMin 2 ;
  fun:argumentTypes ( rdf:Property rdfs:Container ) 
.

set:oldestMember
  rdfs:label "Oldest Member Function"@en ;
  rdfs:comment "The function set:oldestMember selects the oldest member of the container according to a time-stamp property of the member object. The first parameter refers to the property of a member that assigns a time-stamp. This is the time-stamp to be used in the evaluation of this function. The third and all remaining parameters are containers. The function provides the resource as result that is the oldest member object within the union of all containers provided as parameters as indicated by the property of the member object that was specified as first function parameter."@en ;
  rdf:type fun:Function ;
  fun:resultType rdf:Resource ;
  fun:arityMin 2 ;
  fun:argumentTypes ( rdf:Property rdfs:Container )
.

set:resourcesOfType
  rdfs:label "Resources Of Type Function"@en ;
  rdfs:comment "The function set:resourcesOfType represents a container of all resources that are instances of the given classes or its subclasses. Closed world assumption applies. If no argument is given, the resulting container is empty."@en ;
  rdf:type fun:Function ;
  fun:resultType rdfs:Container ;
  fun:argumentTypes ( rdfs:Class )
.

set:resourcesWithProperty
  rdfs:label "Resources With Property Function"@en ;
  rdfs:comment "The function set:resourcesWithProperty represents a container of all resource instances that are subject of the properties given as argument. Closed world assumption applies. If no arguments are given, the resulting container is empty."@en ;
  rdf:type fun:Function ;
  fun:resultType rdfs:Container ;
  fun:argumentTypes ( rdfs:Property )
.

set:resourcesWithPropertyObject
  rdfs:label "Resources With Property Object Function"@en ;
  rdfs:comment "The function set:resourcesWithPropertyObject represents a container of all resources, to which the property specified in the first argument is used to assign any of the objects of the remaining arguments. Closed world assumption applies."@en ;
  rdf:type fun:Function ;
  fun:resultType rdfs:Container ;
  fun:arityMin 2 ;
  fun:argumentTypes ( rdfs:Property rdfs:Resource ) 
.

set:typesOfMembers
  rdfs:label "Types Of Members Function"@en ;
  rdfs:comment "The function set:typesOfMembers represents a container of all classes the elements of the containers in the function arguments are instances of. Duplicates are removed from the resulting container and only included once as member. If no arguments are given, the resulting container is empty."@en ;
  rdf:type fun:Function ;
  fun:resultType rdfs:Container ;
  fun:argumentTypes ( rdfs:Container ) 
.

set:union
  rdfs:label "Union Function"@en ;
  rdfs:comment "The function set:union represents a container of all resources that are members of the containers specified in the function arguments. If no arguments are given, the resulting container is empty."@en ; 
  rdf:type fun:Function ;
  fun:resultType rdfs:Container ;
  fun:argumentTypes ( rdfs:Container )
.

set:valuesOfObjectProperty
  rdfs:label "Values Of Object Property Function"@en ;
  rdfs:comment "The function set:valuesOfObjectProperty represents a container of all values that are assigned with the property given as first argument to the objects provided by the remaining arguments. If and object has multiple values assigned with this property, or if multiple objects are specified, the result is a superset of all values assigned to provided objects with this property."@en ;
  rdf:type fun:Function ;
  fun:resultType rdfs:Container ;
  fun:arityMin 2 ;
  fun:argumentTypes ( rdf:Property rdfs:Resource )
.

set:Vocabulary
  rdfs:label "Set Operators Vocabulary"@en ;
  rdfs:comment "The object set:Vocabulary is a container of all model elements."@en ;
  rdf:type  rdfs:Container ;
  rdfs:member set:difference ,
              set:elementOf ,
              set:empty ,
              set:forAll ,
              set:includedIn ,
              set:intersection ,
              set:intersectsWith ,
              set:isMember ,
              set:membersAfter ,
              set:membersBefore ,
              set:membersSameTime ,
              set:membersWhile ,
              set:newestMember ,
              set:oldestMember ,
              set:resourcesOfType ,
              set:resourcesWithProperty ,
              set:resourcesWithPropertyObject ,
              set:typesOfMembers ,
              set:union ,
              set:valuesOfObjectProperty
.


