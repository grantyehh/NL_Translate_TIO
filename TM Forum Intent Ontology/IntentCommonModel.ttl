# Intent Common Model v3.6.0

@prefix icm:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentCommonModel/> .
@prefix imo:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentManagementOntology/> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix fun:  <http://tio.models.tmforum.org/tio/v3.6.0/FunctionOntology/> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix t:    <http://www.w3.org/2006/time#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

<http://tio.models.tmforum.org/tio/v3.6.0/IntentCommonModel/>
  rdf:type imo:IntentCommonModel ;
  rdfs:label "Intent Common Model"@en ;
  rdfs:Comment "This is the Intent Common Model within the TM Forum Intent Ontology (TIO)"@en ;
  dct:title "Intent Common Model"@en ;
  dct:description "This is the Intent Common Model within the TM Forum Intent Ontology (TIO)"@en ;
  dct:subject "intent model specification"@en ,
              "intent expression"@en ,
              "intent report expression"@en ;
  dct:identifier <http://tio.models.tmforum.org/tio/v3.6.0/IntentCommonModel/> ;
  # dct:isPartOf <http://tio.models.tmforum.org/tio/v3.6.0/TMForumIntentOntology> ;
  dct:replaces <http://tio.models.tmforum.org/tio/v3.5.0/IntentCommonModel/> ;
  dct:contributor <mailto:joerg.niemoeller@ericsson.com> ;
  dct:created "2024-07-26"^^xsd:date ;
  dct:creator <mailto:joerg.niemoeller@ericsson.com> ;
