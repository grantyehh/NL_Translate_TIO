  dct:modified "2024-10-09"^^xsd:date ;
  dct:rights "Copyright © 2024 TM Forum"@en ;
  dct:rightHolder "TM Forum" ;
  dct:publisher "TM Forum" ;
  rdfs:seeAlso <https://www.tmforum.org/resources/how-to-guide/ig1253-intent-in-autonomous-networks-v1-3-0/> ;
  rdfs:seeAlso <https://www.tmforum.org/resources/introductory-guide/intent-common-model-intent-expression-v3-6-0-tr290a/> ;
  rdfs:seeAlso <https://www.tmforum.org/resources/introductory-guide/intent-common-model-intent-reporting-v3-6-0-tr290b/> ;
  rdfs:seeAlso <https://www.tmforum.org/resources/standard/ig1358-intent-based-operation-user-guide-v1-0-0/> ;
  skos:changeNote "2024-07-26 - initial draft of turtle file"@en ;
  skos:changeNote "2024-10-09 - editorial correction in turtle file"@en 
.

icm:about
  rdfs:label "About Property"@en ;
  rdfs:comment "The property icm:about references the intent element the intent report element is reporting about."@en ;
  rdf:type rdf:Property 
.

icm:chooseFrom
  rdfs:label "Choose From Property"@en ;
  rdfs:comment "The property icm:chooseFrom provides a container of resources in its range. These are the resources, from which a choice can be made. The intent handler can choose a single resource or several depending on the use case specific needs. These resources would then be considered additions to the target assigned to the delivery expectation."@en ;
  rdf:type rdf:Property ;
  rdfs:domain icm:DeliveryExpectation ;
  rdfs:range rdfs:Container 
.

icm:ConditionReport
  rdfs:label "Condition Report Class"@en ;
  rdfs:comment "The report for a condition object is provided by an instance of class icm:ConditionReport."@en ;
  rdf:type rdfs:Class 
.

icm:Context
  rdfs:label "Context Class"@en ;
  rdfs:comment "The class icm:Context expresses that its instances are providing contextual information to other intent elements. Context objects provide additional information which impacts the interpretation of requirements. The intent common model does not define specific types of context, but intent extension models can define subclasses of icm:Context to do so."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf icm:IntentElement
.

icm:context
  rdfs:label "Context Property"@en ;
  rdfs:comment "The property icm:context allows assigning context objects to resources and in particular to elements of an intent. The intent common model does not specific types of context, but intent extension models can define sub properties of icm:context specific to subclasses of context."@en ;
  rdf:type rdf:Property ;
  rdfs:range icm:Context
.

icm:ContextReport
  rdfs:label "Context Report Class"@en ;
  rdfs:comment "A report about a context is provided by an instance of class icm:ContextReport."@en ;
  rdf:type rdfs:Class
.

icm:contextReport
  rdfs:label "Context Report Property"@en ;
  rdfs:comment "The property icm:contextReport can be used to assign context reports to elements of the intent report that reports about the elements of an intent that had the respective context."@en ;
  rdf:type rdf:Property ;
  rdfs:range icm:ContextReport
.

icm:deliveryDescription
  rdfs:label "Delivery Description Property"@en ;
  rdfs:comment "The property icm:deliveryDescription is a parameter used in delivery expectations. It expresses where a detailed description of the expected delivery can be found and specifies the resource that contains if."@en ;
  rdf:type rdf:Property ;
  rdfs:domain icm:DeliveryExpectation ;
  rdfs:range rdfs:Resource
.

icm:DeliveryExpectation
  rdfs:label "Delivery Expectation Class"@en ;
  rdfs:comment "The class icm:DeliveryExpectation expresses that its instance is a special type of expectation for specifying the requirement that something needs to be delivered. The details are expressed by its properties."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf icm:Expectation
.

icm:DeliveryExpectationReport
  rdfs:label "Delivery Expectation Report Class"@en ;
  rdfs:comment "The report for a delivery expectation is provided by an instance of class icm:DeliveryExpectationReport within an Intent Report."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf icm:ExpectationReport
.

icm:deliveryType
  rdfs:label "Delivery Type Property"@en ;
  rdfs:comment "The property icm:deliveryType is a parameter used in delivery expectations. It expresses the requirement that the target resource shall be an instance of the specified class."@en ;
  rdf:type rdf:Property ;
  rdfs:domain icm:DeliveryExpectation ;
  rdfs:range rdfs:Class
.

icm:Expectation
  rdfs:label "Expectation Class"@en ;
  rdfs:comment "The class icm:Expectation expresses that its intent is an expectation object. It defines a set of requirements within an Intent."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf icm:IntentElement
.

icm:ExpectationReport
  rdfs:label "Expectation Report Class"@en ;
  rdfs:comment "The class icm:ExpectationReport with its subclasses represent the reports for expectations defined in an intent."@en ;
  rdf:type rdfs:Class 
.

icm:Information
  rdfs:label "Intent Element Class"@en ;
  rdfs:comment "The instances of class icm:Information provide additional information about resources and in particular intent or intent report elements. Information objects provide additional insights and context but without impacting the interpretation of requirements. The intent common model does not define specific types of information, but intent extension models can add subclasses of icm:Information to do so."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf icm:IntentElement
.

icm:information
  rdfs:label "Information Class"@en ;
  rdfs:comment "The property icm:information allows assigning information objects to resources and in particular to elements of an intent or intent report. The intent common model does not define specific types of information, but intent extension models can add subclasses of icm:Information and also define respective sub properties of icm:information with a range specific to subclasses of information."@en ;
  rdf:type rdf:Property ;
  rdfs:range icm:Information
.

icm:Intent
  rdfs:label "Intent Class"@en ;
  rdfs:comment "The class icm:Intent expresses that its instance is an intent object. As such it defines requirements."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf icm:IntentElement 
.

icm:IntentReport
  rdfs:label "Intent Report Class"@en ;
  rdfs:comment "Intent reports are instances of the class icm:IntentReport."@en ;
  rdf:type rdfs:Class
.

icm:IntentElement
  rdfs:label "Intent Element Class"@en ;
  rdfs:comment "Objects of class icm:intentElement are distinct components of the intent expression. Intent elements participate in defining requirements and intent reports can provide details about them."@en ;
  rdfs:type rdfs:Class
.

icm:intentElements
  rdfs:label "Intent Elements Function"@en ;
  rdfs:comment "The function icm:intentElements represents a container of all individual intent element resources used to express requirements for the intent elements given as arguments. This includes the given intent element object itself and its parents. It represents all intent elements in the subtree that contains the function argument."@en ;
  rdf:type fun:Function ;
  fun:resultTtype rdfs:Container ;
  fun:argumentTypes ( icm:IntentElement ) 
.

icm:intentHandlingState
  rdfs:label "Intent Handling State Property"@en ;
  rdfs:comment "The intent handler maintains an intent handling state machine for every intent. An intent report states the intent handling state at the moment of intent report generation using of the property icm:intentHandlingState."@en ;
  rdf:type rdf:Property ;
  rdfs:domain icm:IntentReport ;
  rdfs:range imo:IntentHandlingState
.

icm:intentUpdateState
  rdfs:label "Intent Update State Property"@en ;
  rdfs:comment "The intent handler maintains an intent update state machine for every intent. An intent report states the intent update state at the moment of intent report generation using of the property icm:intentUpdateState."@en ;
  rdf:type rdf:Property ;
  rdfs:domain icm:IntentReport ;
  rdfs:range imo:IntentHandlingState
.

icm:ObservationReportingExpectation
  rdfs:label "Observation Reporting Expectation Class"@en ;
  rdfs:comment "Requesting intent reports with reporting expectations of class icm:ObservationReportingExpectaion leads to intent reports containing observations for metrics used in the intent."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf icm:ReportingExpectation
.

icm:PropertyExpectation
  rdfs:label "Property Expectation Class"@en ;
  rdfs:comment "The class icm:PropertyExpectation expresses that its instance is a special type of expectation for specifying requirements based on properties such as, for example, metrics, KPI, states and other observations."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf icm:Expectation
.

icm:PropertyExpectationReport
  rdfs:label "Property Expectation Report Class"@en ;
  rdfs:comment "The report for a property expectation is provided by an instance of class icm:PropertyExpectationReport within an intent report."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf  icm:ExpectationReport
.

icm:Reason
  rdfs:label "Reason Class"@en ;
  rdfs:comment "Instances of class icm:Reason specify explanations for intent handling results."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf icm:ExpectationReport
.

icm:reason
  rdfs:label "Reason Property"@en ;
  rdfs:comment "The property icm:reason would assign a reason to an intent report element."@en ;
  rdf:type rdf:Property ;
  rdfs:range icm:Reason
.

icm:reportDestination
  rdfs:label "Report Destination Property"@en ;
  rdfs:comment "The property icm:reportDestination is used with a reporting expectation, and it specifies where to send the required report to. The object of the property is a resource that represents a wanted receiver of the intent report. When a report is generated, it would be sent to this receiver."@en ;
  rdf:type rdf:Property ;
  rdfs:domain icm:ReportingExpectation
.

icm:reportDestinations
  rdfs:label "Report Destinations Property"@en ;
  rdfs:comment "The property icm:reportDestinations is used with a reporting expectation, and it specifies where to send the required report to. The object of the property is a container with member resources that represent the wanted receivers of the intent report. When a report is generated, it would be sent to all receivers specified in the container."@en ;
  rdf:type rdf:Property ;
  rdfs:domain icm:ReportingExpectation ;
  rdfs:range rdfs:Container
.

icm:reportGenerated
  rdfs:label "Report Generated Property"@en ;
  rdfs:comment "The property icm:reportGenerated assigns the timestamp of report generation to an intent report instance."@en ;
  rdf:type rdf:Property ;
  rdfs:domain icm:IntentReport ;
  rdfs:range t:Instant
.

icm:ReportingExpectation
  rdfs:label "Reporting Expectation Class"@en ;
  rdfs:comment "The class icm:ReportingExpectation expresses that its instance is a special type of expectation for specifying the conditions and scope of intent reports. It allows subscribing to intent reports and determine its content and condition of generation."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf icm:Expectation
.

icm:ReportingExpectationReport
  rdfs:label "Reporting Expectation Report Class"@en ;
  rdfs:comment "The report for a reporting expectation is provided by an instance of class icm:ReportingExpectationReport."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf icm:ExpectationReport
.

icm:reportNumber
  rdfs:label "Report Number Property"@en ;
  rdfs:comment "The property icm:reportNumber assigns a sequence number to the intent report instance."@en ;
  rdf:type rdf:Property ;
  rdfs:domain icm:IntentReport ;
  rdfs:range xsd:positiveInteger
.

icm:reportTriggers
  rdfs:label "Report Triggers Property"@en ;
  rdfs:comment "The property icm:reportTriggers specifies the events that shall initiate the generation and distribution of an intent report. It is a property used in reporting expectations."@en ;
  rdf:type rdf:Property ;
  rdfs:domain icm:ReportingExpectation ;
  rdfs:range rdfs:Container 
  # container with members of type imo:Event
.

icm:result
  rdfs:label "Result Property"@en ;
  rdfs:comment "The property icm:result states the evaluation result of the intent element at the time of report generation. It is a boolean truth value."@en ;
  rdf:type rdf:Property ;
  rdfs:range xsd:boolean
.

icm:resultFrom
  rdfs:label "Result From Property"@en ;
  rdfs:comment "The property icm:resultFrom associates an element of the intent report with another element of an intent report. Its subject is the report of an intent element that has a boolean truth value resulting from a logical evaluation. The object of icm:resultFrom is the report of an element in the intent that directly contributed to that evaluation."@en ;
  rdf:type rdf:Property
.

icm:Target
  rdfs:label "Target Class"@en ;
  rdfs:comment "The class icm:Target expresses that its instance is a target specification. Targets define a set of resources that are expected to fulfill the requirements they are associated with through an expectation."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf rdfs:Container ;
  rdfs:subClassOf icm:IntentElement
.

icm:target
  rdfs:label "Target Property"@en ;
  rdfs:comment "The property icm:target assigns an object of class icm:Target to an expectation. It therefore specifies the targets for all requirements within this expectation."@en ;
  rdf:type rdf:Property ;
  rdfs:domain icm:Expectation ;
  rdfs:range icm:Target
.

icm:targetCount
  rdfs:label "Target Count Property"@en ;
  rdfs:comment "The property icm:targetCount specifies the number of member resources of the target report object."@en ;
  rdf:type rdf:Property ;
  rdfs:domain icm:TargetReport ;
  rdfs:range xsd:nonNegativeInteger 
.

icm:TargetReport
  rdfs:label "Target Report Class"@en ;
  rdfs:comment "The report for a target is provided by an instance of class icm:TargetReport."@en ;
  rdf:type rdfs:Class
.

icm:targetReport
  rdfs:label "Target Report Property"@en ;
  rdfs:comment "The report for a target is assigned to an expectation report with the property icm:targetReport."@en ;
  rdf:type rdf:Property ;
  rdfs:domain icm:ExpectationReport ;
  rdfs:range icm:TargetReport
.

icm:valuesOfTargetProperty
  rdfs:label "Values of Target Property Function"@en ;
  rdfs:comment "The function icm:valuesOfTargetProperty represents a container of all values that are assigned to members of the target container with the properties specified as function argument. If multiple properties are specified as arguments the result is a superset of all values from all specified properties."@en ;
  rdf:type fun:Function ;
  fun:resultType xsd:boolean ;
  fun:arityMin 1 ;
  fun:argumentTypes ( rdf:Property ) 
.

icm:Vocabulary
  rdfs:label "Intent Common Model Vocabulary"@en ;
  rdfs:comment "The object icm:Vocabulary is a container of all model elements."@en ;
  rdf:type rdfs:Container ;
  rdfs:member icm:about , 
              icm:chooseFrom , 
			  icm:ConditionReport ,
			  icm:Context ,
			  icm:context ,
			  icm:ContextReport ,
			  icm:contextReport ,
			  icm:deliveryDescription ,
			  icm:DeliveryExpectation ,
			  icm:DeliveryExpectationReport ,
			  icm:deliveryType ,
			  icm:Expectation ,
			  icm:ExpectationReport ,
			  icm:Information ,
			  icm:information ,
			  icm:Intent ,
			  icm:IntentReport ,
			  icm:IntentElement ,
			  icm:intentElements ,
			  icm:intentHandlingState ,
			  icm:intentUpdateState ,
			  icm:ObservationReportingExpectation ,
			  icm:PropertyExpectation ,
			  icm:PropertyExpectationReport ,
			  icm:Reason ,
			  icm:reason ,
			  icm:reportDestination ,
			  icm:reportDestinations ,
			  icm:reportGenerated ,
			  icm:ReportingExpectation ,
			  icm:ReportingExpectationReport ,
			  icm:reportNumber ,
			  icm:reportTriggers ,
			  icm:result ,
			  icm:resultFrom ,
			  icm:Target ,
			  icm:target ,
			  icm:targetCount ,
			  icm:TargetReport ,
			  icm:targetReport ,
			  icm:valuesOfTargetProperty
.

