<http://tio.models.tmforum.org/tio/v3.6.0/LogicalOperators/>
  rdf:type imo:BaseOntologyModel ;
  rdfs:label "Conditions and Logical Operators Ontology"@en ;
  rdfs:Comment "The conditions and logical operators ontology model introduces a set of logical operators available for expressing logical relationships in intent modeling."@en ;
  dct:title "Conditions and Logical Operators Ontology"@en ;
  dct:description "The conditions and logical operators ontology model introduces a set of logical operators available for expressing logical relationships in intent modeling."@en ;
  dct:subject "logical operators"@en ,
              "condition expression"@en ,
              "intent expression"@en ;
  dct:identifier <http://tio.models.tmforum.org/tio/v3.6.0/LogicalOperators/> ;
  # dct:isPartOf <http://tio.models.tmforum.org/tio/v3.6.0/TMForumIntentOntology> ;
