  dct:publisher "TM Forum" ;
  rdfs:seeAlso <https://www.tmforum.org/resources/how-to-guide/ig1253-intent-in-autonomous-networks-v1-3-0/> ;
  rdfs:seeAlso <https://www.tmforum.org/resources/introductory-guide/tr292c-function-definition-ontology-v3-6-0/> ;
  rdfs:seeAlso <https://www.tmforum.org/resources/standard/ig1358-intent-based-operation-user-guide-v1-0-0/> ;
  skos:changeNote "2024-10-09 - initial draft of turtle file"@en ;
  skos:changeNote "2024-10-09 - Error correction: removed fum:resultProperty. This is an error not yet fixed in the published vocabulary reference of v3.6.0, but corrected already in this file."@en ;
  skos:changeNote "2024-10-09 - Error correction: add fum:resultIfInvalid. This is an error not yet fixed in the published vocabulary reference of v3.6.0, but corrected already in this file."@en 
.

fun:argumentNames
  rdfs:label "Argument Names Property"@en ;
  rdfs:comment "The property fun:argumentNames is used in function definitions. It allows connecting each argument of the function to a property of the function. The range of fun:argumentNames is a list which contains one entry per function argument in the order of function arguments. Each entry refers to a property and is interpreted as a property of the function. The properties can be provided directly in the function definition and outside the arguments as well. The values provided for a property in the arguments has preference and would override the values assigned directly to the function. This means the equivalent properties used directly in the function definition are defaults."@en ;
  rdf:type rdf:Property ;
  rdfs:domain fun:function ;
  rdfs:range rdfs:List
.

fun:argumentTypes
  rdfs:label "Argument Types Property"@en ;
  rdfs:comment "The property fun:argumentTypes defines the type of each argument of a function. It uses a collection of types expressing the type of each respective argument of the function. For example, if the 1st member of the collection of fun:argumentTypes is rdf:Container and the second member is quan:Quantity, this means that the first argument of the function needs to be a container and the second argument needs to be a quantity. If the function can have more arguments than matched by elements in fun:argumentTypes, the last defined type determines the type of all additional arguments."@en ;
  rdf:type rdf:Property ;
  rdfs:domain fun:function ;
  rdfs:range rdfs:List
.

fun:arityMax
  rdfs:label "Max Arity Property"@en ;
  rdfs:comment "Defines the maximum number of arguments the function would consider. If the argument collection of the function contains more entries, only the entries up to the max arity are considered, and further entries are ignored."@en ;
  rdf:type rdf:Property ;
  rdfs:domain fun:Function ;
  rdfs:range xsd:nonNegativeInteger
.

fun:arityMin
  rdfs:label "Min Arity Property"@en ;
  rdfs:comment "Defines the minimum number of arguments the function requires."@en ;
  rdf:type rdf:Property ;
  rdfs:domain fun:Function ;
  rdfs:range xsd:nonNegativeInteger
.

fun:Error
  rdfs:label "Function Error Class"@en ;
  rdfs:comment "Instances of class fun:Error are types of errors related to functions and function evaluation. It is a specialization of class imo:Error, which refers to all errors happening in intent handling."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf imo:Error
.

fun:Function
  rdfs:label "Function Property"@en ;
  rdfs:comment "An instance of fun:Function represents a function. It is a sub-property of rdf:Property. Therefore, instances of fun:function can be used as properties in statements. The range of all instances of fun:Function is a list. It represents the list of function arguments."@en ;
  rdf:subPropertyOf: rdf:Property ;
  rdfs:range rdf:List
.

fun:resultIfInvalid
  rdfs:label "Result If Invalid Property"@en ;
  rdfs:comment "The property fun:resultIfInvalid allows specifying a result value to be used in case the function is not valid."@en ;
  rdf:type rdf:Property ;
  rdfs:domain fun:Function 
.

fun:resultType
  rdfs:label "Result Type Property"@en ;
  rdfs:comment "Defines the type of the function evaluation result. This is synonymous to the type of value associated with the subject from function evaluation."@en ;
  rdf:type rdf:Property ;
  rdfs:domain fun:Function ;
.

fun:Vocabulary
  rdfs:label "Function Definition Vocabulary"@en ;
  rdfs:comment "The object fun:Vocabulary is a container of all model elements."@en ;
  rdf:type rdfs:Container ;
  rdfs:member fun:argumentNames ,
              fun:argumentTypes ,
              fun:arityMax ,
              fun:arityMin ,
              fun:Error ,
              fun:Function ,
              fun:resultIfInvalid ,
              fun:resultType ,
              fun:Warning 
.

fun:Warning
  rdfs:label "Function Warning Class"@en ;
  rdfs:comment "Instances of class fun:Warning are types of warnings related to functions and function evaluation. It is a specialization of class imo:Warning, which refers to all warnings generated in intent handling."@en ;
  rdf:type rdfs:Class ;
  rdfs:subClassOf imo:Warning
.

