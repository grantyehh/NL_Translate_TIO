# Function Definition Ontology version 3.6.0

@prefix fun:  <http://tio.models.tmforum.org/tio/v3.6.0/FunctionOntology/> .
@prefix imo:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentManagementOntology/> .
@prefix quan: <http://tio.models.tmforum.org/tio/v3.6.0/QuantityOntology/> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

<http://tio.models.tmforum.org/tio/v3.6.0/FunctionOntology/>
  rdf:type imo:BaseOntologyModel ;
  rdfs:label "Function Definition Ontology"@en ;
  rdfs:Comment "This is the Function Definition Ontology model within the TM Forum Intent Ontology (TIO). It provides vocabulary for defining properties that can be used as functions. Functions have a list of arguments in their range and provide an result value. Functions defined based on this ontology can be used as elements in intent expression. They improve intuition when working with the intent models."@en ;
  dct:title "Function Definition Ontology"@en ;
  dct:description "This is the Function Definition Ontology model within the TM Forum Intent Ontology (TIO). It provides vocabulary for defining properties that can be used as functions. Functions have a list of arguments in their range and provide an result value. Functions defined based on this ontology can be used as elements in intent expression. They improve intuition when working with the intent models."@en ;
  dct:subject "function defintion"@en ,
              "intent expression"@en ;
  dct:identifier <http://tio.models.tmforum.org/tio/v3.6.0/FunctionOntology/> ;
  # dct:isPartOf <http://tio.models.tmforum.org/tio/v3.6.0/TMForumIntentOntology> ;
  dct:replaces <http://tio.models.tmforum.org/tio/v3.5.0/FunctionOntology/> ;
  dct:contributor <mailto:joerg.niemoeller@ericsson.com> ;
  dct:created "2024-10-09"^^xsd:date ;
