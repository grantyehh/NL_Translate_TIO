# Utility Model v3.6.0

@prefix ut:   <http://tio.models.tmforum.org/tio/v3.6.0/Utility/> .
@prefix icm:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentCommonModel/> .
@prefix imo:  <http://tio.models.tmforum.org/tio/v3.6.0/IntentManagementOntology/> .
@prefix fun:  <http://tio.models.tmforum.org/tio/v3.6.0/FunctionOntology/> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

<http://tio.models.tmforum.org/tio/v3.6.0/Utility/>
  rdf:type imo:IntentExtensionModel ;
  rdfs:label "Utility Model"@en ;
  rdfs:Comment "The utility intent extension model introduces utility information to be added into an intent."@en ;
  dct:title "Utility Model"@en ;
  dct:description "The utility intent extension model introduces utility information to be added into an intent."@en ;
  dct:subject "intent utility"@en ,
              "intent expression"@en ;
  dct:identifier <http://tio.models.tmforum.org/tio/v3.6.0/Utility/> ;
  # dct:isPartOf <http://tio.models.tmforum.org/tio/v3.6.0/TMForumIntentOntology> ;
  dct:replaces <http://tio.models.tmforum.org/tio/v3.5.0/Utility/> ;
  dct:contributor <mailto:joerg.niemoeller@ericsson.com> ;
  dct:created "2024-10-16"^^xsd:date ;
  dct:creator <mailto:joerg.niemoeller@ericsson.com> ;
